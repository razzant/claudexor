{
  "name": "claudexor-monorepo",
  "version": "0.10.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "schema:gen": "tsx packages/schema/scripts/gen-jsonschema.ts",
    "gen:version": "node scripts/gen-version.mjs",
    "bench:bundle": "node benchmarks/terminal_bench/scripts/bundle-cli.mjs",
    "docs:check": "node scripts/docs-truth-check.mjs",
    "staged:check": "node scripts/staged-field-check.mjs",
    "knip": "knip",
    "clean": "rimraf \"packages/*/dist\" \"packages/*/*.tsbuildinfo\" .turbo \"packages/*/.turbo\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:verify:node": "pnpm typecheck && pnpm test && pnpm schema:gen && git diff --exit-code packages/schema/generated && test -z \"$(git ls-files --others --exclude-standard packages/schema/generated)\" && pnpm docs:check && pnpm staged:check && pnpm knip && pnpm build",
    "release:verify:swift": "(cd apps/macos/ClaudexorKit && PATH=\"$HOME/.swiftly/bin:$PATH\" swift test) && (cd apps/macos/ClaudexorApp && PATH=\"$HOME/.swiftly/bin:$PATH\" swift build)",
    "release:verify:app": "PATH=\"$HOME/.swiftly/bin:$HOME/.claudex/node/bin:$PATH\" MAKE_DMG=1 apps/macos/scripts/build-app.sh",
    "release:verify": "pnpm release:verify:node && pnpm release:verify:swift && pnpm release:verify:app",
    "release:npm": "pnpm release:verify && changeset publish",
    "release": "pnpm release:verify"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.0",
    "knip": "^6.16.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
