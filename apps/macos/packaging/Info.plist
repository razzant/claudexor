<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the notarized Claudexor.app bundle. The dev workflow runs the SwiftPM
  executable directly (`swift run ClaudexorApp`); scripts/build-app.sh assembles a real
  .app around the release binary using this file. Version strings are substituted by the
  script (CLAUDEXOR_VERSION / CLAUDEXOR_BUILD) so they stay in one place.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Claudexor</string>
    <key>CFBundleDisplayName</key>
    <string>Claudexor</string>
    <key>CFBundleIdentifier</key>
    <string>com.claudexor.ClaudexorApp</string>
    <key>CFBundleExecutable</key>
    <string>ClaudexorApp</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>__CLAUDEXOR_VERSION__</string>
    <key>CFBundleVersion</key>
    <string>__CLAUDEXOR_BUILD__</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>26.0</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.developer-tools</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Claudexor. MIT License.</string>
    <!-- Single-window app; no document types. -->
    <key>LSUIElement</key>
    <false/>
    <!-- Screen capture: the composer's Capture button uses the system screencapture
         to grab a region the user chooses to show the agent. macOS gates this behind
         Screen Recording permission; this string explains the prompt. -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>Claudexor captures a screen region you choose so you can attach it to a message for the coding agent.</string>
</dict>
</plist>
