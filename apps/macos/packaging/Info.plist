<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the notarized Claudex.app bundle. The dev workflow runs the SwiftPM
  executable directly (`swift run ClaudexApp`); scripts/build-app.sh assembles a real
  .app around the release binary using this file. Version strings are substituted by the
  script (CLAUDEX_VERSION / CLAUDEX_BUILD) so they stay in one place.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Claudex</string>
    <key>CFBundleDisplayName</key>
    <string>Claudex</string>
    <key>CFBundleIdentifier</key>
    <string>com.claudex.ClaudexApp</string>
    <key>CFBundleExecutable</key>
    <string>ClaudexApp</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>__CLAUDEX_VERSION__</string>
    <key>CFBundleVersion</key>
    <string>__CLAUDEX_BUILD__</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>26.0</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.developer-tools</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Claudex. MIT License.</string>
    <!-- Single-window app; no document types. -->
    <key>LSUIElement</key>
    <false/>
</dict>
</plist>
