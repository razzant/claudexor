{
  "name": "@claudexor/cli",
  "version": "2.1.1",
  "license": "MIT",
  "description": "Claudexor CLI (claudexor). Thin surface over the orchestrator.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node -e \"const {existsSync}=require('node:fs'); for (const f of ['dist/cli.js','dist/claudexord.js','dist/setup-login-runner.js']) if (!existsSync(f)) { console.error('prepublishOnly: missing '+f+' — run pnpm build before publishing'); process.exit(1); }\""
  },
  "dependencies": {
    "@claudexor/acp-server": "workspace:*",
    "@claudexor/artifact-store": "workspace:*",
    "@claudexor/config": "workspace:*",
    "@claudexor/control-api": "workspace:*",
    "@claudexor/delivery": "workspace:*",
    "@claudexor/core": "workspace:*",
    "@claudexor/daemon": "workspace:*",
    "@claudexor/mcp-server": "workspace:*",
    "@claudexor/gateway": "workspace:*",
    "@claudexor/interview": "workspace:*",
    "@claudexor/journal": "workspace:*",
    "@claudexor/orchestrator": "workspace:*",
    "@claudexor/review": "workspace:*",
    "@claudexor/harness-claude": "workspace:*",
    "@claudexor/harness-codex": "workspace:*",
    "@claudexor/harness-cursor": "workspace:*",
    "@claudexor/harness-fake": "workspace:*",
    "@claudexor/harness-opencode": "workspace:*",
    "@claudexor/harness-raw-api": "workspace:*",
    "@claudexor/schema": "workspace:*",
    "@claudexor/secrets": "workspace:*",
    "@claudexor/util": "workspace:*",
    "@claudexor/workspace": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razzant/claudexor.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/razzant/claudexor#readme",
  "bugs": {
    "url": "https://github.com/razzant/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./cli": "./dist/cli.js",
    "./claudexord": "./dist/claudexord.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
