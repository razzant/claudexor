{
  "name": "@claudexor/mcp-server",
  "version": "2.1.1",
  "license": "MIT",
  "description": "MCP server exposing durable Claudexor run, status, cancel, result, and interaction tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@claudexor/schema": "workspace:*",
    "@claudexor/util": "workspace:*",
    "@modelcontextprotocol/server": "2.0.0-beta.1"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razzant/claudexor.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/razzant/claudexor#readme",
  "bugs": {
    "url": "https://github.com/razzant/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
