{
  "name": "@claudexor/mcp-server",
  "version": "1.0.0",
  "license": "MIT",
  "description": "MCP server (official SDK, stdio) exposing Claudexor run/status tools with elicitation-backed interactive questions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@claudexor/schema": "workspace:*",
    "@claudexor/util": "workspace:*",
    "@modelcontextprotocol/server": "2.0.0-beta.1"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joi-lab/claudexor.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/joi-lab/claudexor#readme",
  "bugs": {
    "url": "https://github.com/joi-lab/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
