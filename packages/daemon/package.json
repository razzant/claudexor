{
  "name": "@claudexor/daemon",
  "version": "0.14.1",
  "license": "MIT",
  "description": "Optional local daemon: Unix-socket JSON-RPC, token auth, task queue. Runner injected (no second scheduler).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/event-log": "workspace:*",
    "@claudexor/schema": "workspace:*",
    "@claudexor/util": "workspace:*"
  }
}
