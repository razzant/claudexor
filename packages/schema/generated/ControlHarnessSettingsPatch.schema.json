{
  "$ref": "#/definitions/ControlHarnessSettingsPatch",
  "definitions": {
    "ControlHarnessSettingsPatch": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultModel": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            {
              "type": "null"
            }
          ]
        },
        "effort": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh",
                "max"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "maxTurns": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": true,
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "maxRounds": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": true,
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "maxUsd": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "toolsAllow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ControlHarnessSettingsPatch/properties/defaultModel/anyOf/0"
          }
        },
        "toolsDeny": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ControlHarnessSettingsPatch/properties/defaultModel/anyOf/0"
          }
        },
        "fallbackModel": {
          "anyOf": [
            {
              "$ref": "#/definitions/ControlHarnessSettingsPatch/properties/defaultModel/anyOf/0"
            },
            {
              "type": "null"
            }
          ]
        },
        "web": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "cached",
            "live"
          ]
        },
        "authPreference": {
          "type": "string",
          "enum": [
            "subscription",
            "api_key",
            "auto"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
