{
  "$ref": "#/definitions/RunTelemetry",
  "definitions": {
    "RunTelemetry": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 2,
          "description": "Schema version of the artifact; bumped on breaking ABI changes."
        },
        "run_id": {
          "type": "string",
          "minLength": 1,
          "description": "Run the telemetry belongs to."
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "description": "Task the run belongs to."
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "plan",
            "agent"
          ],
          "description": "Canonical run mode: ask and plan are read-only, agent writes. Engine strategies (race width, attempts, deep_scan, create, delegate) are flags on a mode, not modes."
        },
        "requested_access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ],
          "description": "Access profile the caller requested."
        },
        "effective_access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ],
          "description": "Access profile actually enforced by the engine."
        },
        "external_context_policy": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "cached",
            "live"
          ],
          "description": "Requested web policy for the run."
        },
        "effective_web_mode": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "cached",
            "live"
          ],
          "description": "Web policy actually executed by the selected route."
        },
        "web_required": {
          "type": "boolean",
          "default": false,
          "description": "Whether the run required web evidence."
        },
        "final_attempt_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "description": "Non-empty identifier string."
            },
            {
              "type": "null"
            }
          ],
          "description": "Attempt whose output became the final answer/patch; null when no attempt succeeded.",
          "default": null
        },
        "web": {
          "type": "object",
          "properties": {
            "required": {
              "type": "boolean",
              "default": false,
              "description": "Whether the run required web evidence."
            },
            "policy": {
              "type": "string",
              "enum": [
                "off",
                "auto",
                "cached",
                "live"
              ],
              "description": "Requested web policy for the run.",
              "default": "auto"
            },
            "effective_mode": {
              "$ref": "#/definitions/RunTelemetry/properties/web/properties/policy",
              "default": "auto",
              "description": "Policy actually executed by the harness route (disclosed upgrades, e.g. cached to live)."
            },
            "attempted": {
              "type": "boolean",
              "default": false,
              "description": "Whether any web activity was attempted."
            },
            "satisfied": {
              "type": "boolean",
              "default": false,
              "description": "Whether the web-evidence requirement was satisfied."
            },
            "status": {
              "type": "string",
              "enum": [
                "none",
                "attempted",
                "satisfied",
                "failed",
                "unverified"
              ],
              "description": "Web-evidence verdict for an attempt/run: none (no web activity), attempted, satisfied (required evidence produced), failed, or unverified.",
              "default": "none"
            },
            "verification": {
              "type": "string",
              "enum": [
                "verified",
                "dispatched",
                "none"
              ],
              "default": "none",
              "description": "Retrieval strength of the web evidence: verified (typed retrieval), dispatched (completed but no typed outcome), or none."
            },
            "tool": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Web tool that produced the evidence, when any."
            },
            "target": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Redacted target (query/url) of the web activity, when any."
            },
            "error_summary": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Redacted error detail when web activity failed."
            }
          },
          "additionalProperties": false,
          "description": "Run-level web evidence: the final attempt's evidence, else the most severe attempt evidence."
        },
        "attempts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "attempt_id": {
                "type": "string",
                "minLength": 1,
                "description": "Attempt id."
              },
              "harness_id": {
                "type": "string",
                "minLength": 1,
                "description": "Harness that ran the attempt."
              },
              "observed_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model the harness stream actually reported; null when never disclosed (rendered as unverified, never guessed)."
              },
              "auth_mode": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "local_session",
                      "api_key",
                      "unknown"
                    ],
                    "description": "Auth mode a route runs under: a native local session, an API key, or unknown."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Auth route the attempt actually ran under (local_session subscription vs api_key), disclosed by the adapter's typed started payload; null when never disclosed (treated as unknown, never guessed).",
                "default": null
              },
              "auth_source": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "native_session",
                      "oauth_token_env",
                      "api_key_env",
                      "api_key_flag",
                      "provider_auth_file",
                      "none"
                    ],
                    "description": "Concrete credential source used or probed by a harness."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Concrete credential source the attempt disclosed (native_session/api_key_env/...); null when never disclosed.",
                "default": null
              },
              "profile_id": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Credential profile the attempt actually ran under (adapter-stamped); null = engine default or undisclosed."
              },
              "requested_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model hint the engine sent the attempt; null when the route ran on its default."
              },
              "request_requirements": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "capability": {
                      "type": "string",
                      "enum": [
                        "browser",
                        "path_deny"
                      ]
                    },
                    "harness_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "eligible": {
                      "type": "boolean"
                    },
                    "requested": {
                      "type": "boolean"
                    },
                    "effective": {
                      "type": "boolean"
                    },
                    "reason": {
                      "type": "string",
                      "enum": [
                        "not_requested",
                        "effective",
                        "manifest_unsupported",
                        "web_policy_off",
                        "access_profile_incompatible",
                        "postdiff_only"
                      ]
                    },
                    "evidence_refs": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "default": []
                    }
                  },
                  "required": [
                    "capability",
                    "harness_id",
                    "eligible",
                    "requested",
                    "effective",
                    "reason"
                  ],
                  "additionalProperties": false,
                  "description": "Preflight resolution of one requested capability on one selected harness lane."
                },
                "default": [],
                "description": "Per-lane requested/effective capability receipts computed at preflight; never inferred by surfaces."
              },
              "web": {
                "type": "object",
                "properties": {
                  "required": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/required"
                  },
                  "policy": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/policy"
                  },
                  "effective_mode": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/effective_mode"
                  },
                  "attempted": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/attempted"
                  },
                  "satisfied": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/satisfied"
                  },
                  "status": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/status"
                  },
                  "verification": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/verification"
                  },
                  "tool": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/tool"
                  },
                  "target": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/target"
                  },
                  "error_summary": {
                    "$ref": "#/definitions/RunTelemetry/properties/web/properties/error_summary"
                  }
                },
                "additionalProperties": false,
                "description": "Typed web-evidence record computed by the orchestrator; surfaces project it and never re-derive evidence from raw events."
              },
              "tool_errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "tool": {
                      "type": "string",
                      "description": "Native tool name that errored."
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "web",
                        "file",
                        "command",
                        "mcp",
                        "search",
                        "other"
                      ],
                      "description": "Coarse tool classification used for typed governance; adapters map native tool names to a kind.",
                      "default": "other"
                    },
                    "target": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Redacted target of the tool use, when known."
                    },
                    "summary": {
                      "type": "string",
                      "description": "Redacted error summary."
                    },
                    "recovered": {
                      "type": "boolean",
                      "default": false,
                      "description": "True when a later successful result of the same tool exists in the same attempt."
                    },
                    "tool_use_id": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Tool use id correlating the error to its call, when known."
                    }
                  },
                  "required": [
                    "tool",
                    "summary"
                  ],
                  "additionalProperties": false,
                  "description": "One tool error observed during an attempt."
                },
                "default": [],
                "description": "Tool errors, bounded by the writer (most recent first when truncated; tool_errors_total keeps the true count)."
              },
              "tool_errors_total": {
                "type": "integer",
                "minimum": 0,
                "default": 0,
                "description": "True total count of tool errors."
              },
              "unrecovered_tool_errors": {
                "type": "integer",
                "minimum": 0,
                "default": 0,
                "description": "Tool errors with no later successful recovery."
              },
              "statusless_tool_results": {
                "type": "integer",
                "minimum": 0,
                "default": 0,
                "description": "tool_result events that arrived without a status field (never treated as ok)."
              },
              "dropped_events": {
                "type": "integer",
                "minimum": 0,
                "default": 0,
                "description": "Native lines/events the adapter could not parse or did not recognize (never silently zero)."
              },
              "transient_failures": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "network",
                        "stream_disconnect",
                        "service_unavailable",
                        "timeout",
                        "unknown"
                      ],
                      "default": "unknown",
                      "description": "Fine-grained kind of transient failure (adapter-declared)."
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "timeout",
                        "rate_limited",
                        "auth_failed",
                        "capability_refused",
                        "process_crash",
                        "config_error",
                        "unknown_harness_error"
                      ],
                      "description": "Typed failure category (GH #31) the retry policy and required-actions read; orthogonal to kind.",
                      "default": "unknown_harness_error"
                    },
                    "retryable": {
                      "type": "boolean",
                      "default": false,
                      "description": "Whether the classified category is retryable (the centralized retry-policy gate)."
                    },
                    "retry_delay_ms": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "minimum": 0
                        },
                        {
                          "type": "null"
                        }
                      ],
                      "default": null,
                      "description": "Suggested retry delay in milliseconds, when reported."
                    },
                    "http_status": {
                      "anyOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "null"
                        }
                      ],
                      "default": null,
                      "description": "Vendor HTTP status code disclosed by the error, when any; null otherwise."
                    },
                    "signal": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Process termination signal (e.g. SIGKILL) when a crash killed the child; null otherwise."
                    },
                    "adapter_code": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Vendor/adapter error-category code passed verbatim as evidence; null when none."
                    }
                  },
                  "additionalProperties": false,
                  "description": "An adapter-declared transient failure that informed bounded retry policy."
                },
                "default": [],
                "description": "Adapter-declared transient failures that informed bounded retry policy."
              },
              "outcome": {
                "type": "object",
                "properties": {
                  "deliverable_present": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether the attempt produced the deliverable the intent asked for."
                  },
                  "gates_passed": {
                    "type": [
                      "boolean",
                      "null"
                    ],
                    "default": null,
                    "description": "Whether deterministic gates passed; null when no gates ran."
                  },
                  "harness_errored": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether the harness itself errored."
                  },
                  "web_required_unsatisfied": {
                    "type": "boolean",
                    "default": false,
                    "description": "True when required web evidence was not satisfied."
                  },
                  "delegation_belt_unavailable": {
                    "type": "boolean",
                    "default": false,
                    "description": "True when --delegate requested the belt but the injected MCP server failed to become operational (QA-024); blocks a silent clean success."
                  },
                  "tool_warnings_count": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0,
                    "description": "Count of tool warnings in the attempt."
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "success",
                      "success_with_warnings",
                      "blocked",
                      "failed"
                    ],
                    "description": "Outcome of one attempt: success, success_with_warnings, blocked, or failed.",
                    "default": "success"
                  },
                  "work_state": {
                    "type": "object",
                    "properties": {
                      "state": {
                        "type": "string",
                        "enum": [
                          "completed",
                          "needs_input",
                          "incomplete",
                          "unverified"
                        ],
                        "description": "Folded work state: the WorkReport state, or unverified when no report was obtainable (transport unsupported / lane gated)."
                      },
                      "source": {
                        "type": "string",
                        "enum": [
                          "constrained",
                          "validated",
                          "absent"
                        ],
                        "description": "Provenance of a WorkReport: constrained (native schema transport), validated (whole-answer JSON), or absent (no transport could carry one — a disclosed absence, not a failure)."
                      },
                      "required_inputs": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "enum": [
                                "file",
                                "context",
                                "credential",
                                "permission",
                                "decision",
                                "external_dependency"
                              ],
                              "description": "Category of a missing input a needs_input/incomplete report lists: a file, additional context, a credential, a permission, a human decision, or an external dependency."
                            },
                            "locator": {
                              "anyOf": [
                                {
                                  "type": "string",
                                  "maxLength": 512
                                },
                                {
                                  "type": "null"
                                }
                              ],
                              "default": null,
                              "description": "Concrete pointer to the missing thing (path/url/name); null when unnameable."
                            },
                            "description": {
                              "type": "string",
                              "maxLength": 1024,
                              "description": "Human-readable description of what is needed and why."
                            }
                          },
                          "required": [
                            "kind",
                            "description"
                          ],
                          "additionalProperties": false,
                          "description": "One blocking input a needs_input/incomplete WorkReport lists."
                        },
                        "maxItems": 16,
                        "description": "Carried through from a needs_input/incomplete WorkReport for honest disclosure."
                      }
                    },
                    "required": [
                      "state",
                      "source"
                    ],
                    "additionalProperties": false,
                    "description": "D-16 model-attested work outcome for the attempt (from its WorkReport), orthogonal to status; absent when the route has no work_report transport."
                  }
                },
                "additionalProperties": false,
                "description": "Contract/outcome truth for one attempt; tool errors are tracked separately from deliverable production.",
                "default": {}
              },
              "delegation_belt": {
                "type": "object",
                "properties": {
                  "requested": {
                    "type": "boolean",
                    "default": false,
                    "description": "A Claudexor delegation belt MCP server was injected into this attempt's sandbox."
                  },
                  "server_name": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null,
                    "description": "The injected belt MCP server name (as the harness reports it); null when unknown."
                  },
                  "ready": {
                    "type": "boolean",
                    "default": false,
                    "description": "The harness reported the injected belt MCP server as connected/ready."
                  },
                  "failed": {
                    "type": "boolean",
                    "default": false,
                    "description": "The harness reported the injected belt MCP server as failed to start."
                  },
                  "tool_evidence": {
                    "type": "boolean",
                    "default": false,
                    "description": "At least one belt tool (mcp__<server>__*) was actually invoked in this attempt."
                  }
                },
                "additionalProperties": false,
                "description": "Runtime readiness receipt for the injected Claudexor delegation belt on one attempt (QA-024)."
              },
              "browser": {
                "type": "object",
                "properties": {
                  "requested": {
                    "type": "boolean",
                    "default": false,
                    "description": "The engine armed (injected) the browser MCP for this attempt."
                  },
                  "server_name": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null,
                    "description": "The injected browser MCP server name; null when not armed."
                  },
                  "attempted": {
                    "type": "boolean",
                    "default": false,
                    "description": "At least one browser MCP tool call (matched to the injected server) occurred."
                  },
                  "satisfied": {
                    "type": "boolean",
                    "default": false,
                    "description": "At least one browser MCP tool call succeeded (trusted live-web activity)."
                  },
                  "failed": {
                    "type": "boolean",
                    "default": false,
                    "description": "A browser MCP tool call failed and was not superseded by a success."
                  },
                  "unused": {
                    "type": "boolean",
                    "default": false,
                    "description": "The browser was armed but never called while generic web evidence satisfied the run (disclosure only; not a failure)."
                  }
                },
                "additionalProperties": false,
                "description": "Runtime browser-MCP evidence for one attempt (QA-040)."
              },
              "usage": {
                "type": "object",
                "properties": {
                  "input_tokens": {
                    "anyOf": [
                      {
                        "type": "integer",
                        "minimum": 0
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "output_tokens": {
                    "anyOf": [
                      {
                        "type": "integer",
                        "minimum": 0
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  },
                  "cached_input_tokens": {
                    "anyOf": [
                      {
                        "type": "integer",
                        "minimum": 0
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "default": null
                  }
                },
                "additionalProperties": false,
                "description": "Token usage summed from harness usage events; money is tracked separately in the budget ledger, not here. Each field is null until a harness reports it (cursor reports cost only; raw-api has no cached), so unreported never reads as 0. Do NOT sum into a grand total: codex cached is a subset of input while claude cached is disjoint from input.",
                "default": {}
              }
            },
            "required": [
              "attempt_id",
              "harness_id",
              "web"
            ],
            "additionalProperties": false,
            "description": "Telemetry for one attempt: route evidence, web evidence, tool errors, dropped events, and outcome."
          },
          "default": [],
          "description": "Per-attempt telemetry records."
        },
        "request_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RunTelemetry/properties/attempts/items/properties/request_requirements/items"
          },
          "default": [],
          "description": "All selected-lane capability receipts for this run."
        },
        "tool_warnings_total": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Sum of attempt tool warnings; rendered separately from terminal state."
        },
        "usage_totals": {
          "$ref": "#/definitions/RunTelemetry/properties/attempts/items/properties/usage",
          "default": {},
          "description": "Token usage summed from harness usage events; money is tracked separately in the budget ledger, not here. Each field is null until a harness reports it (cursor reports cost only; raw-api has no cached), so unreported never reads as 0. Do NOT sum into a grand total: codex cached is a subset of input while claude cached is disjoint from input."
        },
        "auth_route": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "requested": {
                  "type": "string",
                  "enum": [
                    "subscription",
                    "api_key",
                    "auto"
                  ],
                  "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret."
                },
                "effective": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/RunTelemetry/properties/attempts/items/properties/auth_mode/anyOf/0"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "description": "Auth mode a route runs under: a native local session, an API key, or unknown.",
                  "default": null
                },
                "source": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/RunTelemetry/properties/attempts/items/properties/auth_source/anyOf/0"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "description": "Concrete credential source used or probed by a harness.",
                  "default": null
                },
                "reason": {
                  "type": "string",
                  "enum": [
                    "as_requested",
                    "native_first",
                    "no_native_session_fallback",
                    "requested_route_unavailable",
                    "undisclosed"
                  ],
                  "description": "Deterministic reason for the effective auth route: as_requested, native_first (auto, INV-061), no_native_session_fallback (auto downgraded to api_key), requested_route_unavailable (explicit preference contradicted), or undisclosed."
                },
                "harness_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "attempt_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "profile_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null,
                  "description": "Credential profile the deciding attempt ran under; null = engine-default credentials."
                },
                "model_mismatch": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "requested": {
                          "type": "string"
                        },
                        "observed": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "requested",
                        "observed"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null,
                  "description": "Requested-vs-observed model mismatch on the deciding attempt; null when they match or either side is unknown."
                }
              },
              "required": [
                "requested",
                "reason"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Auth route receipt: requested preference, disclosed effective route/source, deterministic reason, and the disclosing attempt; surfaces project it verbatim."
        },
        "routing_rationale": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "goal": {
                  "type": "string",
                  "enum": [
                    "auto",
                    "quality",
                    "economy"
                  ],
                  "description": "Routing objective: pace expiring quota, choose the highest declared quality tier, or minimize incremental paid spend."
                },
                "paid_fallback": {
                  "type": "string",
                  "enum": [
                    "never",
                    "when_unavailable",
                    "allowed_within_cap"
                  ],
                  "description": "When a route with incremental paid spend may be used."
                },
                "order": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/RunTelemetry/properties/final_attempt_id/anyOf/0"
                  },
                  "default": [],
                  "description": "Final ranked order, harness ids."
                },
                "dropped": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/RunTelemetry/properties/final_attempt_id/anyOf/0"
                  },
                  "default": [],
                  "description": "Ids removed by paid_fallback or cooldown before ranking."
                },
                "reason": {
                  "type": "string",
                  "enum": [
                    "subscription_entitlement_first",
                    "lowest_incremental_cash",
                    "quality_tier",
                    "expiring_quota_slack",
                    "all_incremental_cash_unknown",
                    "declared_order"
                  ],
                  "description": "Typed decisive reason the pool ranked the way it did (QA-034)."
                },
                "entries": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "harness_id": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Candidate harness id."
                      },
                      "billing_knowledge": {
                        "type": "string",
                        "enum": [
                          "proven_zero",
                          "subscription_entitlement",
                          "metered",
                          "unknown"
                        ],
                        "description": "Effective billing knowledge used to rank it."
                      },
                      "incremental_cost_usd": {
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "default": null,
                        "description": "Known incremental cash cost, when any; null when unknown."
                      },
                      "eligible": {
                        "type": "boolean",
                        "description": "Whether the candidate survived paid_fallback/cooldown filtering."
                      }
                    },
                    "required": [
                      "harness_id",
                      "billing_knowledge",
                      "eligible"
                    ],
                    "additionalProperties": false,
                    "description": "Per-candidate billing/cost tuple in the routing rationale (QA-034)."
                  },
                  "default": []
                }
              },
              "required": [
                "goal",
                "paid_fallback",
                "reason"
              ],
              "additionalProperties": false,
              "description": "Typed routing rationale recorded once at pool ordering (QA-034)."
            },
            {
              "type": "null"
            }
          ],
          "description": "Typed routing rationale recorded once at pool ordering (QA-034); null on legacy artifacts or when no ranking was computed.",
          "default": null
        },
        "generated_at": {
          "type": "string",
          "minLength": 1,
          "description": "When the telemetry artifact was generated."
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "task_id",
        "mode",
        "requested_access",
        "effective_access",
        "external_context_policy",
        "effective_web_mode",
        "web",
        "generated_at"
      ],
      "additionalProperties": false,
      "description": "Run telemetry artifact (final/telemetry.yaml), the single computed source of web/tool evidence; surfaces project it and never re-derive evidence from raw events."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
