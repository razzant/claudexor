{
  "$ref": "#/definitions/WorkProduct",
  "definitions": {
    "WorkProduct": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Work product id."
        },
        "kind": {
          "type": "string",
          "enum": [
            "patch",
            "new_repo",
            "report"
          ],
          "description": "Kind of work product a run produces: a patch against the base tree, a newly created repository, or a report document."
        },
        "source_task_id": {
          "type": "string",
          "minLength": 1,
          "description": "Task the work product came from."
        },
        "producer_attempt_id": {
          "type": "string",
          "minLength": 1,
          "description": "Attempt that produced it, when known."
        },
        "evidence_dir": {
          "type": "string",
          "description": "Directory holding run evidence artifacts."
        },
        "files": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Kind-specific file payload, e.g. artifact name to path (validated loosely here; specialized per kind by callers)."
        },
        "meta": {
          "type": "object",
          "additionalProperties": {},
          "default": {},
          "description": "Kind-specific metadata."
        }
      },
      "required": [
        "id",
        "kind",
        "source_task_id"
      ],
      "additionalProperties": false,
      "description": "The deliverable a run produced (patch, new repo, or report), referenced by apply/delivery verbs."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
