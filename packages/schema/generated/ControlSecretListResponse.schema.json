{
  "$ref": "#/definitions/ControlSecretListResponse",
  "definitions": {
    "ControlSecretListResponse": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "string",
          "const": "file",
          "description": "Active Claudexor v2 file secret store."
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Secret name/label."
              },
              "backend": {
                "type": "string",
                "const": "file",
                "description": "Claudexor v2 file secret store."
              },
              "present": {
                "type": "boolean",
                "default": true,
                "description": "Whether a value is stored."
              }
            },
            "required": [
              "name",
              "backend"
            ],
            "additionalProperties": false,
            "description": "Secret metadata; never the value."
          },
          "default": [],
          "description": "Stored secret metadata."
        }
      },
      "required": [
        "backend"
      ],
      "additionalProperties": false,
      "description": "Metadata-only response for listing stored secrets."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
