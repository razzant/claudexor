{
  "$ref": "#/definitions/ControlApplyRequest",
  "definitions": {
    "ControlApplyRequest": {
      "type": "object",
      "properties": {
        "target": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "original_project"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false
            }
          ],
          "default": {
            "kind": "original_project"
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "artifact_only",
            "apply",
            "branch",
            "commit",
            "pr"
          ],
          "default": "apply"
        },
        "branch": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
