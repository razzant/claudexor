{
  "$ref": "#/definitions/ControlApplyRequest",
  "definitions": {
    "ControlApplyRequest": {
      "type": "object",
      "properties": {
        "target": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "original_project"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "description": "Apply to the project the run originally came from."
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string",
                  "description": "Absolute path of the target project root."
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false,
              "description": "Apply to an explicitly named project root."
            }
          ],
          "description": "Where a work product is delivered: the original project or an explicit project root.",
          "default": {
            "kind": "original_project"
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "artifact_only",
            "apply",
            "branch",
            "commit",
            "pr"
          ],
          "default": "apply",
          "description": "Delivery mode: artifact_only (export only), apply to the tree, or as a branch, commit, or PR."
        },
        "branch": {
          "type": "string",
          "description": "Branch name for branch/pr modes."
        },
        "message": {
          "type": "string",
          "description": "Commit message for commit/pr modes."
        }
      },
      "additionalProperties": false,
      "description": "Request body applying a run's work product to a project."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
