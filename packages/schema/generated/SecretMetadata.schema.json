{
  "$ref": "#/definitions/SecretMetadata",
  "definitions": {
    "SecretMetadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Secret name/label."
        },
        "backend": {
          "type": "string",
          "const": "file",
          "description": "Claudexor v2 file secret store."
        },
        "present": {
          "type": "boolean",
          "default": true,
          "description": "Whether a value is stored."
        }
      },
      "required": [
        "name",
        "backend"
      ],
      "additionalProperties": false,
      "description": "Secret metadata; never the value."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
