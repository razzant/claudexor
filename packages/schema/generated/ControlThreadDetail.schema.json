{
  "$ref": "#/definitions/ControlThreadDetail",
  "definitions": {
    "ControlThreadDetail": {
      "type": "object",
      "properties": {
        "thread": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "repoRoot": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "mode": {
              "type": "string",
              "enum": [
                "ask",
                "plan",
                "audit",
                "agent",
                "orchestrate"
              ]
            },
            "workspaceMode": {
              "type": "string",
              "enum": [
                "in_place",
                "isolated"
              ],
              "default": "in_place"
            },
            "authPreference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "default": "auto"
            },
            "primaryHarness": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "eligibleHarnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "portfolio": {
              "type": "string",
              "enum": [
                "daily-rich",
                "balanced",
                "cheapest",
                "strongest",
                "burn",
                "subscription-first",
                "api-overflow",
                "conserve-claude",
                "conserve-codex"
              ]
            },
            "state": {
              "type": "string",
              "enum": [
                "active",
                "closed"
              ],
              "default": "active"
            },
            "runIds": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "default": []
            },
            "headRunId": {
              "anyOf": [
                {
                  "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "needsHuman": {
              "type": "boolean",
              "default": false
            },
            "createdAt": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "createdAt",
            "updatedAt"
          ],
          "additionalProperties": false
        },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "threadId": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "harnessId": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "providerFamily": {
                "type": "string",
                "enum": [
                  "openai",
                  "anthropic",
                  "google",
                  "cursor",
                  "opencode",
                  "xai",
                  "local",
                  "unknown"
                ],
                "default": "unknown"
              },
              "nativeSessionId": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "observedModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "state": {
                "type": "string",
                "enum": [
                  "live",
                  "stale",
                  "rebound"
                ],
                "default": "live"
              }
            },
            "required": [
              "id",
              "threadId",
              "harnessId"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "turns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "threadId": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
              },
              "runId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "parentRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "planRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/id"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "kind": {
                "type": "string",
                "enum": [
                  "initial",
                  "followup",
                  "decision"
                ],
                "default": "followup"
              },
              "prompt": {
                "type": "string",
                "default": ""
              },
              "run": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "state": {
                        "type": "string",
                        "enum": [
                          "queued",
                          "running",
                          "blocked",
                          "succeeded",
                          "no_op",
                          "ungated",
                          "review_not_run",
                          "failed",
                          "cancelled",
                          "interrupted",
                          "exhausted",
                          "not_converged"
                        ]
                      },
                      "mode": {
                        "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/mode"
                      },
                      "strategy": {
                        "anyOf": [
                          {
                            "type": "string",
                            "enum": [
                              "race",
                              "attempts",
                              "until_clean",
                              "swarm",
                              "create"
                            ]
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "n": {
                        "type": "integer"
                      },
                      "result": {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "enum": [
                              "patch",
                              "answer",
                              "plan",
                              "report",
                              "none"
                            ],
                            "default": "none"
                          },
                          "diffStat": {
                            "anyOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "files": {
                                    "type": "integer",
                                    "minimum": 0
                                  },
                                  "additions": {
                                    "type": "integer",
                                    "minimum": 0
                                  },
                                  "deletions": {
                                    "type": "integer",
                                    "minimum": 0
                                  }
                                },
                                "required": [
                                  "files",
                                  "additions",
                                  "deletions"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "null"
                              }
                            ],
                            "default": null
                          },
                          "blockers": {
                            "type": "integer",
                            "minimum": 0,
                            "default": 0
                          },
                          "adopted": {
                            "type": [
                              "boolean",
                              "null"
                            ],
                            "default": null
                          },
                          "applyState": {
                            "type": "string",
                            "enum": [
                              "not_applied",
                              "applied",
                              "applied_review_blocked",
                              "reverted"
                            ],
                            "default": "not_applied"
                          },
                          "preTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null
                          },
                          "postTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null
                          },
                          "revertable": {
                            "type": "boolean",
                            "default": false
                          }
                        },
                        "additionalProperties": false,
                        "default": {}
                      },
                      "spendUsd": {
                        "type": [
                          "number",
                          "null"
                        ]
                      },
                      "outputReadyState": {
                        "type": "string",
                        "enum": [
                          "pending",
                          "finalizing",
                          "ready",
                          "diagnostic"
                        ],
                        "default": "pending"
                      },
                      "waitingOnUser": {
                        "type": "boolean",
                        "default": false
                      },
                      "finishedAt": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "default": null
                      }
                    },
                    "required": [
                      "state"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "createdAt": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "threadId",
              "createdAt"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "thread"
      ],
      "additionalProperties": false
    }
  }
}
