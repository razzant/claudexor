{
  "$ref": "#/definitions/ControlThreadDetail",
  "definitions": {
    "ControlThreadDetail": {
      "type": "object",
      "properties": {
        "thread": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Thread id."
            },
            "title": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Thread title; null until set."
            },
            "repoRoot": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Project root the thread is anchored to; null for a no-project thread."
            },
            "mode": {
              "type": "string",
              "enum": [
                "ask",
                "plan",
                "agent",
                "orchestrate"
              ],
              "description": "Default mode for new turns."
            },
            "workspaceMode": {
              "type": "string",
              "enum": [
                "in_place",
                "isolated"
              ],
              "description": "Per-thread workspace mode: in_place mutates the live project tree directly (the default); isolated keeps a persistent git worktree per thread that apply merges into the project.",
              "default": "in_place"
            },
            "authPreference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret.",
              "default": "auto"
            },
            "primaryHarness": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Sticky primary harness for the thread; null = engine routing."
            },
            "eligibleHarnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Sticky eligible harness pool; empty = the engine auto-pools."
            },
            "credentialProfileId": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1,
                  "description": "Non-empty identifier string."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Sticky credential profile for the thread; per-turn selection wins, null = engine-default credentials.",
              "default": null
            },
            "access": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "readonly",
                    "workspace_write",
                    "full",
                    "external_sandbox_full",
                    "inherit_native"
                  ],
                  "description": "Filesystem/command access profile for a run: readonly (no writes), workspace_write (writes inside the workspace only), full (unrestricted; requires the per-repo trust allow), external_sandbox_full (full access inside an external sandbox), inherit_native (defer to the harness's own native sandbox settings)."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Sticky write scope for write turns; null = the repo trust default.",
              "default": null
            },
            "state": {
              "type": "string",
              "enum": [
                "active",
                "closed",
                "trashed",
                "purged"
              ],
              "description": "Thread lifecycle state: active, closed, trashed for recovery, or terminally purged.",
              "default": "active"
            },
            "trashedAt": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "When the thread entered trash."
            },
            "purgeAfter": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "When trash retention expires."
            },
            "runIds": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
              },
              "default": [],
              "description": "Ordered run lineage of the thread."
            },
            "headRunId": {
              "anyOf": [
                {
                  "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Most recent run of the thread; null before the first turn runs.",
              "default": null
            },
            "needsHuman": {
              "type": "boolean",
              "default": false,
              "description": "True when the head turn is blocked on a human decision (needs-me inbox)."
            },
            "createdAt": {
              "type": "string",
              "description": "When the thread was created."
            },
            "updatedAt": {
              "type": "string",
              "description": "When the thread was last updated."
            }
          },
          "required": [
            "id",
            "createdAt",
            "updatedAt"
          ],
          "additionalProperties": false,
          "description": "Control-plane projection of a thread (camelCase view of the Thread artifact)."
        },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Session id."
              },
              "threadId": {
                "type": "string",
                "minLength": 1,
                "description": "Thread the session belongs to."
              },
              "harnessId": {
                "type": "string",
                "minLength": 1,
                "description": "Harness the session is bound to."
              },
              "nativeSessionId": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "The vendor CLI session id; null when none exists."
              },
              "observedModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model last observed on the session's stream."
              },
              "profileId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Credential profile the vendor session was created under; resume never crosses profiles (null = engine-default credentials).",
                "default": null
              },
              "state": {
                "type": "string",
                "enum": [
                  "live",
                  "stale",
                  "rebound"
                ],
                "default": "live",
                "description": "Session cache state: live, stale, or rebound."
              }
            },
            "required": [
              "id",
              "threadId",
              "harnessId"
            ],
            "additionalProperties": false,
            "description": "Control-plane projection of a vendor CLI session bound to a thread."
          },
          "default": [],
          "description": "Vendor sessions bound to the thread."
        },
        "turns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Turn id."
              },
              "threadId": {
                "type": "string",
                "minLength": 1,
                "description": "Thread the turn belongs to."
              },
              "runId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Run backing this turn; null while unbound.",
                "default": null
              },
              "parentRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Run this turn follows up on, when any.",
                "default": null
              },
              "planRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Set when this turn implements an approved plan from an earlier run.",
                "default": null
              },
              "kind": {
                "type": "string",
                "enum": [
                  "initial",
                  "followup",
                  "decision"
                ],
                "description": "Kind of thread turn: the initial message, a followup, or an operator decision turn.",
                "default": "followup"
              },
              "prompt": {
                "type": "string",
                "default": "",
                "description": "The user's message for this turn."
              },
              "run": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "state": {
                        "type": "string",
                        "enum": [
                          "queued",
                          "running",
                          "blocked",
                          "succeeded",
                          "no_op",
                          "ungated",
                          "review_not_run",
                          "failed",
                          "cancelled",
                          "interrupted_unknown",
                          "cost_unverifiable",
                          "exhausted_overshoot",
                          "exhausted",
                          "not_converged",
                          "stuck_no_progress"
                        ],
                        "description": "Control-plane run state: queued/running while live, then an honest success, block, failure, interruption, cost, exhaustion, non-convergence, or cancellation terminal."
                      },
                      "mode": {
                        "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/mode",
                        "description": "Canonical run mode: ask and plan are read-only, agent writes; orchestrate is retained only until delegation replaces it. Engine strategies (race width, attempts, deep_scan, create) are flags on a mode, not modes."
                      },
                      "strategy": {
                        "anyOf": [
                          {
                            "type": "string",
                            "enum": [
                              "race",
                              "attempts",
                              "until_clean",
                              "deep_scan",
                              "create"
                            ]
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "description": "Engine strategy flag on the mode, when any."
                      },
                      "n": {
                        "type": "integer",
                        "description": "Race width, when the run was a race."
                      },
                      "result": {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "enum": [
                              "patch",
                              "answer",
                              "plan",
                              "report",
                              "none"
                            ],
                            "default": "none",
                            "description": "What the turn actually produced: a patch, an answer, a plan (no files changed), a report, or nothing."
                          },
                          "diffStat": {
                            "anyOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "files": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Files changed."
                                  },
                                  "additions": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Lines added."
                                  },
                                  "deletions": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Lines deleted."
                                  }
                                },
                                "required": [
                                  "files",
                                  "additions",
                                  "deletions"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "null"
                              }
                            ],
                            "default": null,
                            "description": "Diff statistics; null unless a patch exists."
                          },
                          "blockers": {
                            "type": "integer",
                            "minimum": 0,
                            "default": 0,
                            "description": "Count of accepted blocking review findings."
                          },
                          "adopted": {
                            "type": [
                              "boolean",
                              "null"
                            ],
                            "default": null,
                            "description": "True when the live in-place tree was mutated this turn (regardless of review); null when unknown."
                          },
                          "applyState": {
                            "type": "string",
                            "enum": [
                              "not_applied",
                              "applied",
                              "applied_review_blocked",
                              "reverted"
                            ],
                            "description": "Honest application state of a run's changes: not_applied (no in-place mutation), applied (applied and review clean), applied_review_blocked (applied but review blocked/unconverged), or reverted.",
                            "default": "not_applied"
                          },
                          "preTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "Tree SHA before this turn mutated the in-place tree (revert restore target)."
                          },
                          "postTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "Tree SHA right after this turn's mutation; revert refuses if the working tree has diverged from this since."
                          },
                          "revertAnchorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "GC-independent revert anchor."
                          },
                          "revertable": {
                            "type": "boolean",
                            "default": false,
                            "description": "Revert metadata is available so a Revert affordance may be offered; not a live-safe guarantee — the server re-checks tree divergence at revert time."
                          }
                        },
                        "additionalProperties": false,
                        "description": "Honest terminal outcome of a run (what the turn actually did), projected from the work product and answer artifacts.",
                        "default": {}
                      },
                      "spendUsd": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "Settled cash in USD; null when unknown."
                      },
                      "outputReadyState": {
                        "type": "string",
                        "enum": [
                          "pending",
                          "finalizing",
                          "ready",
                          "diagnostic"
                        ],
                        "description": "Whether a terminal run also has a loaded user-facing output artifact: pending (not yet), finalizing (being produced), ready (loaded), diagnostic (only diagnostic output).",
                        "default": "pending"
                      },
                      "waitingOnUser": {
                        "type": "boolean",
                        "default": false,
                        "description": "True while an interactive question is awaiting the user's answer."
                      },
                      "finishedAt": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "default": null,
                        "description": "When the run finished; null while live."
                      }
                    },
                    "required": [
                      "state"
                    ],
                    "additionalProperties": false,
                    "description": "Compact run state embedded on a turn so a chat surface renders the whole conversation from one thread fetch."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Embedded run card (outcome/state); null while no run is bound.",
                "default": null
              },
              "enqueueError": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "message": {
                        "type": "string",
                        "description": "Human-readable refusal message."
                      },
                      "code": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "default": null,
                        "description": "Machine-readable refusal code; remedies key on it, never on the message text."
                      },
                      "retryable": {
                        "type": "boolean",
                        "default": true,
                        "description": "False when no recorded job exists to replay — surfaces offer a new message instead of a doomed retry."
                      },
                      "failedAt": {
                        "type": "string",
                        "description": "When the enqueue failed."
                      }
                    },
                    "required": [
                      "message",
                      "failedAt"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Why this turn has no run (enqueue/preflight refusal); null once a run binds."
              },
              "createdAt": {
                "type": "string",
                "description": "When the turn was created."
              }
            },
            "required": [
              "id",
              "threadId",
              "createdAt"
            ],
            "additionalProperties": false,
            "description": "Control-plane projection of one thread turn with its embedded run card."
          },
          "default": [],
          "description": "Turns of the conversation, in order."
        }
      },
      "required": [
        "thread"
      ],
      "additionalProperties": false,
      "description": "Full thread detail served by GET /threads/:id: the thread, its vendor sessions, and its turns."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
