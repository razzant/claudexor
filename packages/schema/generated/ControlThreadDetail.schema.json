{
  "$ref": "#/definitions/ControlThreadDetail",
  "definitions": {
    "ControlThreadDetail": {
      "type": "object",
      "properties": {
        "thread": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Thread id."
            },
            "title": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Thread title; null until set."
            },
            "repoRoot": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Project root the thread is anchored to; null for a no-project thread."
            },
            "mode": {
              "type": "string",
              "enum": [
                "ask",
                "plan",
                "agent"
              ],
              "description": "Default mode for new turns."
            },
            "workspaceMode": {
              "type": "string",
              "enum": [
                "in_place",
                "isolated"
              ],
              "description": "Per-thread workspace mode: in_place mutates the live project tree directly (the default); isolated keeps a persistent git worktree per thread that apply merges into the project.",
              "default": "in_place"
            },
            "authPreference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret.",
              "default": "auto"
            },
            "primaryHarness": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Sticky primary harness for the thread; null = engine routing."
            },
            "eligibleHarnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Sticky eligible harness pool; empty = the engine auto-pools."
            },
            "credentialProfileId": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1,
                  "description": "Non-empty identifier string."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Sticky credential profile for the thread; per-turn selection wins, null = engine-default credentials.",
              "default": null
            },
            "access": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "readonly",
                    "workspace_write",
                    "full",
                    "external_sandbox_full",
                    "inherit_native"
                  ],
                  "description": "Filesystem/command access profile for a run: readonly (no writes), workspace_write (writes inside the workspace only), full (unrestricted; requires the per-repo trust allow), external_sandbox_full (full access inside an external sandbox), inherit_native (defer to the harness's own native sandbox settings)."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Sticky write scope for write turns; null = the repo trust default.",
              "default": null
            },
            "state": {
              "type": "string",
              "enum": [
                "active",
                "closed",
                "trashed",
                "purged"
              ],
              "description": "Thread lifecycle state: active, closed, trashed for recovery, or terminally purged.",
              "default": "active"
            },
            "trashedAt": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "When the thread entered trash."
            },
            "purgeAfter": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "When trash retention expires."
            },
            "runIds": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
              },
              "default": [],
              "description": "Ordered run lineage of the thread."
            },
            "headRunId": {
              "anyOf": [
                {
                  "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Most recent run of the thread; null before the first turn runs.",
              "default": null
            },
            "needsHuman": {
              "type": "boolean",
              "default": false,
              "description": "True when the head turn is blocked on a human decision (needs-me inbox)."
            },
            "createdAt": {
              "type": "string",
              "description": "When the thread was created."
            },
            "updatedAt": {
              "type": "string",
              "description": "When the thread was last updated."
            }
          },
          "required": [
            "id",
            "createdAt",
            "updatedAt"
          ],
          "additionalProperties": false,
          "description": "Control-plane projection of a thread (camelCase view of the Thread artifact)."
        },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Session id."
              },
              "threadId": {
                "type": "string",
                "minLength": 1,
                "description": "Thread the session belongs to."
              },
              "harnessId": {
                "type": "string",
                "minLength": 1,
                "description": "Harness the session is bound to."
              },
              "nativeSessionId": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "The vendor CLI session id; null when none exists."
              },
              "observedModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model last observed on the session's stream."
              },
              "profileId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Credential profile the vendor session was created under; resume never crosses profiles (null = engine-default credentials).",
                "default": null
              },
              "state": {
                "type": "string",
                "enum": [
                  "live",
                  "stale",
                  "rebound"
                ],
                "default": "live",
                "description": "Session cache state: live, stale, or rebound."
              }
            },
            "required": [
              "id",
              "threadId",
              "harnessId"
            ],
            "additionalProperties": false,
            "description": "Control-plane projection of a vendor CLI session bound to a thread."
          },
          "default": [],
          "description": "Vendor sessions bound to the thread."
        },
        "turns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Turn id."
              },
              "threadId": {
                "type": "string",
                "minLength": 1,
                "description": "Thread the turn belongs to."
              },
              "runId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Run backing this turn; null while unbound.",
                "default": null
              },
              "parentRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Run this turn follows up on, when any.",
                "default": null
              },
              "planRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Set when this turn implements an approved plan from an earlier run.",
                "default": null
              },
              "planHash": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "SHA-256 of the frozen plan bytes this Implement turn materialized (INV-081); null on non-Implement/legacy turns (QA-046)."
              },
              "planReadinessOverridden": {
                "type": "boolean",
                "default": false,
                "description": "True when the operator implemented a not-ready plan over open questions (INV-081); recorded for provenance, rendered on the card (QA-046)."
              },
              "kind": {
                "type": "string",
                "enum": [
                  "initial",
                  "followup",
                  "decision"
                ],
                "description": "Kind of thread turn: the initial message, a followup, or an operator decision turn.",
                "default": "followup"
              },
              "prompt": {
                "type": "string",
                "default": "",
                "description": "The user's message for this turn."
              },
              "run": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "state": {
                        "type": "string",
                        "enum": [
                          "queued",
                          "running",
                          "succeeded",
                          "failed",
                          "cancelled",
                          "interrupted"
                        ],
                        "description": "Control-plane run state = the run LIFECYCLE (D8): queued/running while live, then exactly one of succeeded / failed / cancelled / interrupted. Outcome quality (checks/review/delivery) is orthogonal — see outcomeFacts."
                      },
                      "mode": {
                        "$ref": "#/definitions/ControlThreadDetail/properties/thread/properties/mode",
                        "description": "Canonical run mode: ask and plan are read-only, agent writes. Engine strategies (race width, attempts, deep_scan, create, delegate) are flags on a mode, not modes."
                      },
                      "strategy": {
                        "anyOf": [
                          {
                            "type": "string",
                            "enum": [
                              "race",
                              "attempts",
                              "until_clean",
                              "deep_scan",
                              "create"
                            ]
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "description": "Engine strategy flag on the mode, when any."
                      },
                      "n": {
                        "type": "integer",
                        "description": "Race width, when the run was a race."
                      },
                      "result": {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "enum": [
                              "patch",
                              "answer",
                              "plan",
                              "report",
                              "none"
                            ],
                            "default": "none",
                            "description": "What the turn actually produced: a patch, an answer, a plan (no files changed), a report, or nothing."
                          },
                          "diffStat": {
                            "anyOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "files": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Files changed."
                                  },
                                  "additions": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Lines added."
                                  },
                                  "deletions": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Lines deleted."
                                  }
                                },
                                "required": [
                                  "files",
                                  "additions",
                                  "deletions"
                                ],
                                "additionalProperties": false
                              },
                              {
                                "type": "null"
                              }
                            ],
                            "default": null,
                            "description": "Diff statistics; null unless a patch exists."
                          },
                          "blockers": {
                            "type": "integer",
                            "minimum": 0,
                            "default": 0,
                            "description": "Count of accepted blocking review findings."
                          },
                          "adopted": {
                            "type": [
                              "boolean",
                              "null"
                            ],
                            "default": null,
                            "description": "True when the live in-place tree was mutated this turn (regardless of review); null when unknown."
                          },
                          "applyState": {
                            "type": "string",
                            "enum": [
                              "not_applied",
                              "applied",
                              "applied_review_blocked",
                              "reverted"
                            ],
                            "description": "Honest application state of a run's changes: not_applied (no in-place mutation), applied (applied and review clean), applied_review_blocked (applied but review blocked/unconverged), or reverted.",
                            "default": "not_applied"
                          },
                          "preTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "Tree SHA before this turn mutated the in-place tree (revert restore target)."
                          },
                          "postTurnSha": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "Tree SHA right after this turn's mutation; revert refuses if the working tree has diverged from this since."
                          },
                          "revertAnchorId": {
                            "type": [
                              "string",
                              "null"
                            ],
                            "default": null,
                            "description": "GC-independent revert anchor."
                          },
                          "revertable": {
                            "type": "boolean",
                            "default": false,
                            "description": "Revert metadata is available so a Revert affordance may be offered; not a live-safe guarantee — the server re-checks tree divergence at revert time."
                          }
                        },
                        "additionalProperties": false,
                        "description": "Honest terminal outcome of a run (what the turn actually did), projected from the work product and answer artifacts.",
                        "default": {}
                      },
                      "outcomeFacts": {
                        "anyOf": [
                          {
                            "type": "object",
                            "properties": {
                              "lifecycle": {
                                "type": "string",
                                "enum": [
                                  "succeeded",
                                  "failed",
                                  "cancelled",
                                  "interrupted"
                                ],
                                "description": "Terminal lifecycle of the run."
                              },
                              "noChanges": {
                                "type": "boolean",
                                "default": false,
                                "description": "True when the run finished without changing any files (the ex no_op fact)."
                              },
                              "checks": {
                                "type": "string",
                                "enum": [
                                  "passed",
                                  "failed",
                                  "not_configured"
                                ],
                                "description": "Deterministic checks axis: configured project checks passed, failed, or none are configured (a named state, never a stand-in for review results).",
                                "default": "not_configured"
                              },
                              "review": {
                                "type": "string",
                                "enum": [
                                  "approved",
                                  "blocked",
                                  "not_run"
                                ],
                                "description": "Review axis: approved (clean cross-family verified review), blocked (open accepted findings), or not_run.",
                                "default": "not_run"
                              },
                              "reason": {
                                "anyOf": [
                                  {
                                    "type": "string",
                                    "enum": [
                                      "harness_failed",
                                      "no_changes",
                                      "review_blocked",
                                      "checks_failed",
                                      "budget_exhausted",
                                      "budget_overshoot",
                                      "cost_unverifiable",
                                      "not_converged",
                                      "stuck_no_progress",
                                      "wall_clock_exceeded",
                                      "user_cancelled",
                                      "crash_interrupted",
                                      "input_required",
                                      "work_incomplete",
                                      "context_capacity_exhausted",
                                      "work_report_contract"
                                    ],
                                    "description": "Typed reason qualifying a non-clean terminal; null on a clean success."
                                  },
                                  {
                                    "type": "null"
                                  }
                                ],
                                "description": "Typed reason qualifying a non-clean terminal; null on a clean success.",
                                "default": null
                              },
                              "work_state": {
                                "type": "object",
                                "properties": {
                                  "state": {
                                    "type": "string",
                                    "enum": [
                                      "completed",
                                      "needs_input",
                                      "incomplete",
                                      "unverified"
                                    ],
                                    "description": "Folded work state: the WorkReport state, or unverified when no report was obtainable (transport unsupported / lane gated)."
                                  },
                                  "source": {
                                    "type": "string",
                                    "enum": [
                                      "constrained",
                                      "validated",
                                      "absent"
                                    ],
                                    "description": "Provenance of a WorkReport: constrained (native schema transport), validated (whole-answer JSON), or absent (no transport could carry one — a disclosed absence, not a failure)."
                                  },
                                  "required_inputs": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "kind": {
                                          "type": "string",
                                          "enum": [
                                            "file",
                                            "context",
                                            "credential",
                                            "permission",
                                            "decision",
                                            "external_dependency"
                                          ],
                                          "description": "Category of a missing input a needs_input/incomplete report lists: a file, additional context, a credential, a permission, a human decision, or an external dependency."
                                        },
                                        "locator": {
                                          "anyOf": [
                                            {
                                              "type": "string",
                                              "maxLength": 512
                                            },
                                            {
                                              "type": "null"
                                            }
                                          ],
                                          "default": null,
                                          "description": "Concrete pointer to the missing thing (path/url/name); null when unnameable."
                                        },
                                        "description": {
                                          "type": "string",
                                          "maxLength": 1024,
                                          "description": "Human-readable description of what is needed and why."
                                        }
                                      },
                                      "required": [
                                        "kind",
                                        "description"
                                      ],
                                      "additionalProperties": false,
                                      "description": "One blocking input a needs_input/incomplete WorkReport lists."
                                    },
                                    "maxItems": 16,
                                    "description": "Carried through from a needs_input/incomplete WorkReport for honest disclosure."
                                  }
                                },
                                "required": [
                                  "state",
                                  "source"
                                ],
                                "additionalProperties": false,
                                "description": "D-16 model-attested work outcome, orthogonal to lifecycle; a needs_input/incomplete state vetoes applyability and exit 0. Absent on runs with no work_report transport."
                              }
                            },
                            "required": [
                              "lifecycle"
                            ],
                            "additionalProperties": false,
                            "description": "Independent terminal outcome axes of a run (D8/D18)."
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "description": "D8 terminal outcome axes (checks/review/reason/noChanges) for the turn; null while non-terminal.",
                        "default": null
                      },
                      "spendUsd": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "Settled cash in USD; null when unknown."
                      },
                      "outputReadyState": {
                        "type": "string",
                        "enum": [
                          "pending",
                          "finalizing",
                          "ready",
                          "diagnostic"
                        ],
                        "description": "Whether a terminal run also has a loaded user-facing output artifact: pending (not yet), finalizing (being produced), ready (loaded), diagnostic (only diagnostic output).",
                        "default": "pending"
                      },
                      "waitingOnUser": {
                        "type": "boolean",
                        "default": false,
                        "description": "True while an interactive question is awaiting the user's answer."
                      },
                      "finishedAt": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "default": null,
                        "description": "When the run finished; null while live."
                      }
                    },
                    "required": [
                      "state"
                    ],
                    "additionalProperties": false,
                    "description": "Compact run state embedded on a turn so a chat surface renders the whole conversation from one thread fetch."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Embedded run card (outcome/state); null while no run is bound.",
                "default": null
              },
              "enqueueError": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "message": {
                        "type": "string",
                        "description": "Human-readable refusal message."
                      },
                      "code": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "default": null,
                        "description": "Machine-readable refusal code; remedies key on it, never on the message text."
                      },
                      "retryable": {
                        "type": "boolean",
                        "default": true,
                        "description": "False when no recorded job exists to replay — surfaces offer a new message instead of a doomed retry."
                      },
                      "failedAt": {
                        "type": "string",
                        "description": "When the enqueue failed."
                      }
                    },
                    "required": [
                      "message",
                      "failedAt"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Why this turn has no run (enqueue/preflight refusal); null once a run binds."
              },
              "continuity": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "enum": [
                          "native_resume",
                          "packet",
                          "fresh"
                        ],
                        "description": "How a turn's lane was continued: native_resume (the lane's own vendor session already held the delta), packet (a continuation packet hydrated a lane switch/gap), or fresh (nothing to carry — the thread's first turn on any lane)."
                      },
                      "packetTurns": {
                        "type": "integer",
                        "minimum": 0,
                        "default": 0,
                        "description": "Delta turns carried in the continuation packet (0 for native_resume/fresh)."
                      },
                      "summarized": {
                        "type": "boolean",
                        "default": false,
                        "description": "True when the packet collapsed an older prefix (mechanical fallback)."
                      },
                      "laneSwitchedFrom": {
                        "anyOf": [
                          {
                            "type": "object",
                            "properties": {
                              "harness": {
                                "type": "string",
                                "description": "Harness of the lane switched away from."
                              },
                              "profileId": {
                                "type": [
                                  "string",
                                  "null"
                                ],
                                "default": null,
                                "description": "Profile of the lane switched away from (null = engine default)."
                              }
                            },
                            "required": [
                              "harness"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "null"
                          }
                        ],
                        "default": null,
                        "description": "The lane this turn switched away from; null for an in-lane continuation."
                      }
                    },
                    "required": [
                      "kind"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "How this turn's lane was continued (native resume / packet / fresh); null until stamped."
              },
              "createdAt": {
                "type": "string",
                "description": "When the turn was created."
              }
            },
            "required": [
              "id",
              "threadId",
              "createdAt"
            ],
            "additionalProperties": false,
            "description": "Control-plane projection of one thread turn with its embedded run card."
          },
          "default": [],
          "description": "Turns of the conversation, in order."
        }
      },
      "required": [
        "thread"
      ],
      "additionalProperties": false,
      "description": "Full thread detail served by GET /threads/:id: the thread, its vendor sessions, and its turns."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
