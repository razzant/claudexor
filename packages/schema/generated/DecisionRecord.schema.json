{
  "$ref": "#/definitions/DecisionRecord",
  "definitions": {
    "DecisionRecord": {
      "type": "object",
      "properties": {
        "winner": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "description": "Non-empty identifier string."
            },
            {
              "type": "null"
            }
          ],
          "description": "Winning attempt/candidate id; null when nothing won."
        },
        "facts": {
          "type": "object",
          "properties": {
            "lifecycle": {
              "type": "string",
              "enum": [
                "succeeded",
                "failed",
                "cancelled",
                "interrupted"
              ],
              "description": "Terminal lifecycle of the run."
            },
            "noChanges": {
              "type": "boolean",
              "default": false,
              "description": "True when the run finished without changing any files (the ex no_op fact)."
            },
            "checks": {
              "type": "string",
              "enum": [
                "passed",
                "failed",
                "not_configured"
              ],
              "description": "Deterministic checks axis: configured project checks passed, failed, or none are configured (a named state, never a stand-in for review results).",
              "default": "not_configured"
            },
            "review": {
              "type": "string",
              "enum": [
                "approved",
                "blocked",
                "not_run"
              ],
              "description": "Review axis: approved (clean cross-family verified review), blocked (open accepted findings), or not_run.",
              "default": "not_run"
            },
            "reason": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "harness_failed",
                    "no_changes",
                    "review_blocked",
                    "checks_failed",
                    "budget_exhausted",
                    "budget_overshoot",
                    "cost_unverifiable",
                    "not_converged",
                    "stuck_no_progress",
                    "wall_clock_exceeded",
                    "user_cancelled",
                    "crash_interrupted"
                  ],
                  "description": "Typed reason qualifying a non-clean terminal; null on a clean success."
                },
                {
                  "type": "null"
                }
              ],
              "description": "Typed reason qualifying a non-clean terminal; null on a clean success.",
              "default": null
            }
          },
          "required": [
            "lifecycle"
          ],
          "additionalProperties": false,
          "description": "Independent terminal outcome axes of a run (D8/D18)."
        },
        "why_winner": {
          "type": "string",
          "default": "",
          "description": "Why the winner was chosen."
        },
        "why_not_others": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Per-candidate reasons the others lost, keyed by candidate id."
        },
        "accepted_risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Risks explicitly accepted in the decision."
        },
        "final_checks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Final checks performed before the decision."
        },
        "evidence_facts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Evidence facts the decision rests on."
        },
        "budget_summary": {
          "type": "object",
          "properties": {
            "spend_usd": {
              "type": [
                "number",
                "null"
              ],
              "default": null,
              "description": "Total settled spend in USD; null when unknown."
            },
            "estimated": {
              "type": "boolean",
              "default": false,
              "description": "True when any of the spend is token-derived rather than natively reported."
            }
          },
          "additionalProperties": false,
          "default": {
            "spend_usd": null,
            "estimated": false
          },
          "description": "Settled spend for the run; estimates are disclosed, never presented as exact."
        },
        "apply_recommendation": {
          "type": "string",
          "enum": [
            "apply",
            "inspect",
            "continue",
            "human_review"
          ],
          "description": "Recommended next action for the run's work product: apply it, inspect first, continue working, or get human review.",
          "default": "inspect"
        },
        "verification_basis": {
          "type": "string",
          "enum": [
            "none",
            "cross_family_review",
            "both"
          ],
          "description": "What backed an applyable outcome: none (non-applyable), cross_family_review (a clean cross-family verified review), or both (deterministic gates and that review).",
          "default": "none"
        },
        "final_verify": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "attempted": {
                  "type": "boolean",
                  "description": "Whether the final verify was attempted."
                },
                "base_sha": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null,
                  "description": "Base SHA the verify tree was created from (the winner envelope's base)."
                },
                "applied_cleanly": {
                  "type": [
                    "boolean",
                    "null"
                  ],
                  "default": null,
                  "description": "Whether the patch applied cleanly onto the fresh tree; null when not attempted."
                },
                "gates_passed": {
                  "type": [
                    "boolean",
                    "null"
                  ],
                  "default": null,
                  "description": "Whether the re-run deterministic gates passed; null when not attempted."
                },
                "gates": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Gate id."
                      },
                      "status": {
                        "type": "string",
                        "description": "Gate status."
                      }
                    },
                    "required": [
                      "id",
                      "status"
                    ],
                    "additionalProperties": false
                  },
                  "default": [],
                  "description": "Per-gate re-run results."
                },
                "duration_ms": {
                  "anyOf": [
                    {
                      "type": "integer",
                      "minimum": 0
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null,
                  "description": "How long the verify took, in milliseconds."
                },
                "reason": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null,
                  "description": "Typed reason when attempted=false (e.g. no_patch, no_base_sha) or a failure detail."
                }
              },
              "required": [
                "attempted"
              ],
              "additionalProperties": false,
              "description": "FinalVerifier record: the winner's patch was applied onto a fresh worktree at the candidate's own base SHA and the deterministic gates were re-run there; no model involvement."
            },
            {
              "type": "null"
            }
          ],
          "description": "Final verify record; present only for write runs with a patch (or a recorded reason why the verifier did not run).",
          "default": null
        }
      },
      "required": [
        "winner",
        "facts"
      ],
      "additionalProperties": false,
      "description": "The arbitration decision for a run: winner, outcome axes, reasons, spend, and the verification that backs applyability."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
