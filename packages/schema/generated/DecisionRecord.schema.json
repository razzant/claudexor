{
  "$ref": "#/definitions/DecisionRecord",
  "definitions": {
    "DecisionRecord": {
      "type": "object",
      "properties": {
        "winner": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "no_op",
            "ungated",
            "review_not_run",
            "blocked",
            "not_converged",
            "failed",
            "exhausted",
            "cancelled"
          ]
        },
        "outcome": {
          "type": "string",
          "enum": [
            "ready",
            "no_op",
            "ungated",
            "review_not_run",
            "blocked"
          ],
          "default": "blocked"
        },
        "why_winner": {
          "type": "string",
          "default": ""
        },
        "why_not_others": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "accepted_risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "final_checks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "evidence_facts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "budget_summary": {
          "type": "object",
          "properties": {
            "spend_usd": {
              "type": [
                "number",
                "null"
              ],
              "default": null
            },
            "estimated": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false,
          "default": {
            "spend_usd": null,
            "estimated": false
          }
        },
        "apply_recommendation": {
          "type": "string",
          "enum": [
            "apply",
            "inspect",
            "continue",
            "split_task",
            "human_review"
          ],
          "default": "inspect"
        }
      },
      "required": [
        "winner",
        "status"
      ],
      "additionalProperties": false
    }
  }
}
