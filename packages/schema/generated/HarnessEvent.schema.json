{
  "$ref": "#/definitions/HarnessEvent",
  "definitions": {
    "HarnessEvent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "started",
            "thinking",
            "message",
            "tool_call",
            "tool_result",
            "interaction_requested",
            "file_change",
            "usage",
            "error",
            "completed"
          ]
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "ts": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "tool": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "web",
                "file",
                "command",
                "mcp",
                "search",
                "other"
              ],
              "default": "other"
            },
            "use_id": {
              "type": "string"
            },
            "target": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "ok",
                "error",
                "cancelled",
                "denied"
              ]
            },
            "error_summary": {
              "type": "string"
            },
            "content_summary": {
              "type": "string"
            },
            "exit_code": {
              "type": "integer"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "interaction": {
          "type": "object",
          "properties": {
            "interaction_id": {
              "$ref": "#/definitions/HarnessEvent/properties/session_id"
            },
            "questions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "$ref": "#/definitions/HarnessEvent/properties/session_id"
                  },
                  "question": {
                    "type": "string"
                  },
                  "header": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "type": "string"
                        },
                        "description": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "default": null
                        }
                      },
                      "required": [
                        "label"
                      ],
                      "additionalProperties": false
                    },
                    "default": []
                  },
                  "multi_select": {
                    "type": "boolean",
                    "default": false
                  }
                },
                "required": [
                  "id",
                  "question"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "source_tool": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            }
          },
          "required": [
            "interaction_id"
          ],
          "additionalProperties": false
        },
        "usage": {
          "type": "object",
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "cached_input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "cost_usd": {
              "type": "number",
              "minimum": 0
            },
            "estimated": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "observed_model": {
          "type": "string"
        },
        "quota": {
          "type": "object",
          "properties": {
            "used_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "resets_at": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            }
          },
          "required": [
            "used_percent"
          ],
          "additionalProperties": false
        },
        "plan_progress": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "pending",
                      "in_progress",
                      "completed"
                    ]
                  }
                },
                "required": [
                  "id",
                  "title",
                  "status"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false
        },
        "rate_limit": {
          "type": "object",
          "properties": {
            "resets_at": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "retry_delay_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "additionalProperties": false
        },
        "transient": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "network",
                "stream_disconnect",
                "service_unavailable",
                "timeout",
                "unknown"
              ],
              "default": "unknown"
            },
            "retry_delay_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "additionalProperties": false
        },
        "error": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "type",
        "session_id",
        "ts"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
