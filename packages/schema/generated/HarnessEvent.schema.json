{
  "$ref": "#/definitions/HarnessEvent",
  "definitions": {
    "HarnessEvent": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "started",
            "thinking",
            "message",
            "tool_call",
            "tool_result",
            "interaction_requested",
            "file_change",
            "patch_produced",
            "usage",
            "error",
            "completed"
          ],
          "description": "Normalized event type covering session lifecycle, output, tool use, interaction, file changes, usage, and errors."
        },
        "session_id": {
          "type": "string",
          "minLength": 1,
          "description": "Session the event belongs to."
        },
        "ts": {
          "type": "string",
          "description": "Event timestamp."
        },
        "text": {
          "type": "string",
          "description": "Text content for thinking/message/error events."
        },
        "tool": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Native tool name as the harness reports it."
            },
            "kind": {
              "type": "string",
              "enum": [
                "web",
                "file",
                "command",
                "mcp",
                "search",
                "other"
              ],
              "description": "Coarse tool classification used for typed governance; adapters map native tool names to a kind.",
              "default": "other"
            },
            "use_id": {
              "type": "string",
              "description": "Correlates a tool_result with its tool_call."
            },
            "target": {
              "type": "string",
              "description": "Redacted, bounded human-readable target (query/url/path/command)."
            },
            "status": {
              "type": "string",
              "enum": [
                "ok",
                "error",
                "cancelled",
                "denied"
              ],
              "description": "Outcome of the tool use; required on tool_result events (a missing status is never treated as ok)."
            },
            "error_summary": {
              "type": "string",
              "description": "Redacted, bounded error detail for status=error results."
            },
            "content_summary": {
              "type": "string",
              "description": "Redacted, bounded content detail for results (success or failure)."
            },
            "exit_code": {
              "type": "integer",
              "description": "Process exit code for command tools, when known."
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false,
          "description": "Typed tool info; set on tool_call and tool_result events."
        },
        "interaction": {
          "type": "object",
          "properties": {
            "interaction_id": {
              "type": "string",
              "minLength": 1,
              "description": "Interaction id used to correlate the answer set."
            },
            "questions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Question id."
                  },
                  "question": {
                    "type": "string",
                    "description": "The question text."
                  },
                  "header": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null,
                    "description": "Short chip/header text some harnesses attach to a question."
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "type": "string",
                          "description": "Option label shown to the user."
                        },
                        "description": {
                          "type": [
                            "string",
                            "null"
                          ],
                          "default": null,
                          "description": "Optional longer explanation of the option."
                        }
                      },
                      "required": [
                        "label"
                      ],
                      "additionalProperties": false,
                      "description": "One multiple-choice option of an interactive question."
                    },
                    "default": [],
                    "description": "Selectable options; empty for free-text-only questions."
                  },
                  "multi_select": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether multiple options may be selected."
                  }
                },
                "required": [
                  "id",
                  "question"
                ],
                "additionalProperties": false,
                "description": "One question of an interactive user-input request."
              },
              "default": [],
              "description": "Questions the harness wants answered."
            },
            "source_tool": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Native tool that raised the request (e.g. \"AskUserQuestion\")."
            }
          },
          "required": [
            "interaction_id"
          ],
          "additionalProperties": false,
          "description": "Set on interaction_requested events."
        },
        "patch_envelope": {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "number",
              "const": 1
            },
            "context_packet_hash": {
              "type": "string",
              "minLength": 1,
              "description": "Content hash in algo:hex form, e.g. \"sha256:abcd...\"."
            },
            "base_tree_sha": {
              "type": "string",
              "minLength": 1
            },
            "patch": {
              "type": "string",
              "minLength": 1
            },
            "patch_hash": {
              "$ref": "#/definitions/HarnessEvent/properties/patch_envelope/properties/context_packet_hash"
            },
            "touched_paths": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "expected_blob_oid": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "description": "Base-tree blob oid, or null only when the path is absent in the base tree."
                  }
                },
                "required": [
                  "path",
                  "expected_blob_oid"
                ],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": [
            "schema_version",
            "context_packet_hash",
            "base_tree_sha",
            "patch",
            "patch_hash",
            "touched_paths"
          ],
          "additionalProperties": false,
          "description": "Typed hash-bound patch produced by a git-patch-envelope harness."
        },
        "refusal_code": {
          "type": "string",
          "enum": [
            "raw_patch_requires_isolation",
            "raw_patch_missing_evidence",
            "raw_patch_digest_mismatch",
            "raw_patch_base_mismatch",
            "raw_patch_path_traversal",
            "raw_patch_outside_scope",
            "raw_patch_stale_preimage",
            "raw_patch_binary_unsupported",
            "raw_patch_sensitive_content",
            "raw_patch_truncated",
            "raw_patch_apply_failed"
          ],
          "description": "Typed refusal code for a rejected raw patch contract."
        },
        "usage": {
          "type": "object",
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0,
              "description": "Input tokens consumed."
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0,
              "description": "Output tokens produced."
            },
            "cached_input_tokens": {
              "type": "integer",
              "minimum": 0,
              "description": "Input tokens served from cache."
            },
            "cost_usd": {
              "type": "number",
              "minimum": 0,
              "description": "Cost in USD."
            },
            "estimated": {
              "type": "boolean",
              "description": "True when cost_usd is derived from token pricing (not natively reported)."
            }
          },
          "additionalProperties": false,
          "description": "Token/cost usage reported by the harness."
        },
        "observed_model": {
          "type": "string",
          "description": "Model the harness actually reported using."
        },
        "credential_route": {
          "type": "string",
          "enum": [
            "vendor_native",
            "managed_api_key",
            "local"
          ],
          "description": "Concrete credential route selected before spawn; first-class route evidence, never inferred from free-form payload text."
        },
        "credential_source": {
          "type": "string",
          "enum": [
            "native_session",
            "oauth_token_env",
            "api_key_env",
            "api_key_flag",
            "provider_auth_file",
            "none"
          ],
          "description": "Concrete credential source selected before spawn; exact native subscription requires native_session, never an OAuth token or API key."
        },
        "quota": {
          "type": "object",
          "properties": {
            "used_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Consumed share of the binding rate window, 0-100."
            },
            "resets_at": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Native reset moment for the window, when the CLI reports one."
            }
          },
          "required": [
            "used_percent"
          ],
          "additionalProperties": false,
          "description": "Typed quota/usage-window signal from the harness CLI's own native machine-readable surface, never scraped from prose."
        },
        "plan_progress": {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Plan item id."
                  },
                  "title": {
                    "type": "string",
                    "description": "Plan item title."
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "pending",
                      "in_progress",
                      "completed"
                    ],
                    "description": "Progress state of the item."
                  }
                },
                "required": [
                  "id",
                  "title",
                  "status"
                ],
                "additionalProperties": false
              },
              "default": [],
              "description": "Last-wins list of plan/todo items."
            }
          },
          "additionalProperties": false,
          "description": "Typed live plan/todo progress mapped from the harness's native plan tools, never parsed from prose."
        },
        "rate_limit": {
          "type": "object",
          "properties": {
            "resets_at": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "When the rate window resets, when reported."
            },
            "retry_delay_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Suggested retry delay in milliseconds, when reported."
            }
          },
          "additionalProperties": false,
          "description": "Typed rate-limit/quota signal set by the adapter when the native CLI reports a 429/quota/overload."
        },
        "transient": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "network",
                "stream_disconnect",
                "service_unavailable",
                "timeout",
                "unknown"
              ],
              "default": "unknown",
              "description": "Kind of transient failure."
            },
            "retry_delay_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Suggested retry delay in milliseconds, when reported."
            }
          },
          "additionalProperties": false,
          "description": "Typed transient-failure signal set by the adapter from native CLI/API error shapes, consumed for bounded retry policy."
        },
        "error": {
          "type": "string",
          "description": "Error text for error events."
        },
        "aborted": {
          "type": "boolean",
          "description": "Typed terminal cancellation marker, set on completed events when the run was aborted."
        },
        "payload": {
          "type": "object",
          "additionalProperties": {},
          "description": "Raw adapter-specific payload for diagnostics."
        }
      },
      "required": [
        "type",
        "session_id",
        "ts"
      ],
      "additionalProperties": false,
      "description": "Normalized event emitted by every adapter (the SSOT of adapter output)."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
