{
  "$ref": "#/definitions/ControlThreadApplyResponse",
  "definitions": {
    "ControlThreadApplyResponse": {
      "type": "object",
      "properties": {
        "applied": {
          "type": "boolean",
          "description": "Whether anything was delivered."
        },
        "status": {
          "type": "string",
          "enum": [
            "applied",
            "branched",
            "committed",
            "pr_opened",
            "empty",
            "conflict",
            "rejected"
          ],
          "description": "Delivery outcome: applied, branched, committed, pr_opened, empty (no diff), conflict, or rejected."
        },
        "headMoved": {
          "type": "boolean",
          "default": false,
          "description": "True when the project HEAD moved past the thread base since the thread started."
        },
        "detail": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Human-readable detail."
        },
        "delivery": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "apply",
                    "branch",
                    "commit",
                    "pr"
                  ]
                },
                "applied": {
                  "type": "boolean"
                },
                "branch": {
                  "type": "string"
                },
                "commit": {
                  "type": "string"
                },
                "prUrl": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                },
                "treeMutated": {
                  "type": "boolean"
                },
                "refused": {
                  "type": "boolean"
                },
                "alreadyApplied": {
                  "type": "boolean",
                  "default": false,
                  "description": "True when delivery was an idempotent already-applied no-op (no files changed)."
                },
                "deliveryStatus": {
                  "type": "string",
                  "enum": [
                    "applied",
                    "already_applied",
                    "refused"
                  ],
                  "description": "Coarse typed delivery disposition (applied / already_applied / refused)."
                },
                "finalVerify": {
                  "type": "object",
                  "properties": {
                    "attempted": {
                      "type": "boolean",
                      "description": "Whether the final verify was attempted."
                    },
                    "base_sha": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Base SHA the verify tree was created from (the winner envelope's base)."
                    },
                    "applied_cleanly": {
                      "type": [
                        "boolean",
                        "null"
                      ],
                      "default": null,
                      "description": "Whether the patch applied cleanly onto the fresh tree; null when not attempted."
                    },
                    "gates_passed": {
                      "type": [
                        "boolean",
                        "null"
                      ],
                      "default": null,
                      "description": "Whether the re-run deterministic gates passed; null when not attempted."
                    },
                    "gates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Gate id."
                          },
                          "status": {
                            "type": "string",
                            "description": "Gate status."
                          }
                        },
                        "required": [
                          "id",
                          "status"
                        ],
                        "additionalProperties": false
                      },
                      "default": [],
                      "description": "Per-gate re-run results."
                    },
                    "duration_ms": {
                      "anyOf": [
                        {
                          "type": "integer",
                          "minimum": 0
                        },
                        {
                          "type": "null"
                        }
                      ],
                      "default": null,
                      "description": "How long the verify took, in milliseconds."
                    },
                    "reason": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "default": null,
                      "description": "Typed reason when attempted=false (e.g. no_patch, no_base_sha) or a failure detail."
                    }
                  },
                  "required": [
                    "attempted"
                  ],
                  "additionalProperties": false,
                  "description": "Fresh verifier evidence for this delivery attempt."
                },
                "targetPreimageSha": {
                  "type": "string",
                  "description": "Target snapshot verified immediately before delivery."
                }
              },
              "required": [
                "mode",
                "applied",
                "finalVerify",
                "targetPreimageSha"
              ],
              "additionalProperties": false,
              "description": "Immutable receipt for a freshly verified delivery attempt."
            },
            {
              "type": "null"
            }
          ],
          "description": "Fresh verifier, target preimage, and mutation receipt; null when no delivery ran.",
          "default": null
        }
      },
      "required": [
        "applied",
        "status"
      ],
      "additionalProperties": false,
      "description": "Response to a thread apply."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
