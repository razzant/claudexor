{
  "$ref": "#/definitions/ControlThreadApplyResponse",
  "definitions": {
    "ControlThreadApplyResponse": {
      "type": "object",
      "properties": {
        "applied": {
          "type": "boolean",
          "description": "Whether anything was delivered."
        },
        "status": {
          "type": "string",
          "enum": [
            "applied",
            "branched",
            "committed",
            "pr_opened",
            "empty",
            "conflict",
            "rejected"
          ],
          "description": "Delivery outcome: applied, branched, committed, pr_opened, empty (no diff), conflict, or rejected."
        },
        "headMoved": {
          "type": "boolean",
          "default": false,
          "description": "True when the project HEAD moved past the thread base since the thread started."
        },
        "detail": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Human-readable detail."
        }
      },
      "required": [
        "applied",
        "status"
      ],
      "additionalProperties": false,
      "description": "Response to a thread apply."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
