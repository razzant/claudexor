{
  "$ref": "#/definitions/ControlSettingsUpdateRequest",
  "definitions": {
    "ControlSettingsUpdateRequest": {
      "type": "object",
      "properties": {
        "routingGoal": {
          "type": "string",
          "enum": [
            "auto",
            "quality",
            "economy"
          ],
          "description": "Routing objective: pace expiring quota, choose the highest declared quality tier, or minimize incremental paid spend."
        },
        "paidFallback": {
          "type": "string",
          "enum": [
            "never",
            "when_unavailable",
            "allowed_within_cap"
          ],
          "description": "When a route with incremental paid spend may be used."
        },
        "qualityTiers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "harness": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Non-empty identifier string."
                  },
                  "model": {
                    "type": "string",
                    "minLength": 1
                  },
                  "effort": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "xhigh",
                      "max"
                    ],
                    "description": "Cross-harness reasoning-effort level, weakest to strongest; adapters declare the subset they support and a shared normalizer clamps requests onto the nearest supported level."
                  }
                },
                "required": [
                  "harness",
                  "model",
                  "effort"
                ],
                "additionalProperties": false,
                "description": "An exact harness, model, and effort route declared by the user."
              },
              "minItems": 1,
              "description": "A group of comparable exact routes at one user-declared quality level."
            }
          },
          "propertyNames": {
            "enum": [
              "plan",
              "spec",
              "implement",
              "create_from_scratch",
              "repair",
              "review",
              "verify",
              "synthesize",
              "explain",
              "audit"
            ]
          },
          "default": {},
          "description": "Per-intent quality tiers ordered highest to lowest; no provider or benchmark priors are inferred."
        },
        "interactionTimeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "description": "New interactive-answer timeout, in milliseconds."
        },
        "primaryHarness": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S",
              "description": "User-supplied string that must contain visible content, not just whitespace."
            },
            {
              "type": "null"
            }
          ],
          "description": "New global primary harness; null clears back to engine routing."
        },
        "eligibleHarnesses": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/primaryHarness/anyOf/0"
          },
          "description": "New global eligible harness pool."
        },
        "envInheritance": {
          "type": "string",
          "enum": [
            "mirror_native",
            "clean"
          ],
          "description": "New child harness env composition mode."
        },
        "paidBudgetPerRun": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "unlimited"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "finite"
                },
                "maxUsd": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "kind",
                "maxUsd"
              ],
              "additionalProperties": false
            }
          ],
          "description": "New global incremental-cash budget per run."
        },
        "authPreference": {
          "type": "string",
          "enum": [
            "subscription",
            "api_key",
            "auto"
          ],
          "description": "New global auth route preference."
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Enable/disable the harness for routing."
              },
              "defaultModel": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/primaryHarness/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "New per-harness default model; null clears it."
              },
              "effort": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/qualityTiers/additionalProperties/items/items/properties/effort"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "New default reasoning effort; null clears it."
              },
              "maxTurns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "New max agent turns; null clears the limit."
              },
              "maxRounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "New max convergence rounds; null clears it."
              },
              "toolsAllow": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/primaryHarness/anyOf/0"
                },
                "description": "New tool allowlist."
              },
              "toolsDeny": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/primaryHarness/anyOf/0"
                },
                "description": "New tool denylist."
              },
              "fallbackModel": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/primaryHarness/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "New fallback model; null clears it."
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ],
                "description": "New default web policy."
              },
              "authPreference": {
                "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/authPreference",
                "description": "New auth route preference."
              },
              "profileLimitAction": {
                "type": "string",
                "enum": [
                  "fail",
                  "ask",
                  "rotate"
                ],
                "description": "New profile-selection limit action (fail | ask | rotate)."
              }
            },
            "additionalProperties": false,
            "description": "Partial per-harness settings patch; absent fields keep their stored value, and a typoed key 400s (strict)."
          },
          "propertyNames": {
            "minLength": 1,
            "pattern": "\\S"
          },
          "description": "Per-harness settings patches keyed by harness id."
        }
      },
      "additionalProperties": false,
      "description": "Request body for PATCH /settings; absent fields keep their stored values."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
