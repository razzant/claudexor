            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "benchmark",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "routingPolicy": {
          "type": "string",
          "enum": [
            "auto",
            "primary",
            "portfolio"
          ]
        },
        "primaryHarness": {
          "type": [
            "string",
            "null"
          ]
        },
        "defaultModel": {
          "type": [
            "string",
            "null"
          ]
        },
        "eligibleHarnesses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "envInheritance": {
