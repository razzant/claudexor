{
  "$ref": "#/definitions/ControlSettingsUpdateRequest",
  "definitions": {
    "ControlSettingsUpdateRequest": {
      "type": "object",
      "properties": {
        "defaultPortfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "interactionTimeoutMs": {
          "type": "integer",
          "exclusiveMinimum": true,
          "minimum": 0
        },
        "routingPolicy": {
          "type": "string",
          "enum": [
            "auto",
            "primary",
            "portfolio"
          ]
        },
        "primaryHarness": {
          "type": [
            "string",
            "null"
          ]
        },
        "defaultModel": {
          "type": [
            "string",
            "null"
          ]
        },
        "eligibleHarnesses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "envInheritance": {
          "type": "string",
          "enum": [
            "mirror_native",
            "clean",
            "profile_only"
          ]
        },
        "maxUsdPerRun": {
          "type": "number",
          "minimum": 0
        },
        "maxUsdPerDay": {
          "type": "number",
          "minimum": 0
        },
        "clearMaxUsdPerRun": {
          "type": "boolean"
        },
        "clearMaxUsdPerDay": {
          "type": "boolean"
        },
        "authPreference": {
          "type": "string",
          "enum": [
            "subscription",
            "api_key",
            "auto"
          ]
        },
        "fallbackOnQuotaExhaustion": {
          "type": "string",
          "enum": [
            "subscription_to_api",
            "harness_to_harness",
            "both",
            "off"
          ]
        },
        "fallbackOnMoneyExhaustion": {
          "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/fallbackOnQuotaExhaustion"
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "defaultModel": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "effort": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "xhigh",
                      "max"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "maxTurns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "maxRounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "maxUsd": {
                "anyOf": [
                  {
                    "type": "number",
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "toolsAllow": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "toolsDeny": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "fallbackModel": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ]
              },
              "authPreference": {
                "$ref": "#/definitions/ControlSettingsUpdateRequest/properties/authPreference"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
