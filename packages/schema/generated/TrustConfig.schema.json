{
  "$ref": "#/definitions/TrustConfig",
  "definitions": {
    "TrustConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1,
          "description": "Config format version."
        },
        "access_default": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ],
          "description": "Default access profile for runs in this repo.",
          "default": "workspace_write"
        },
        "allow_full_access": {
          "type": "boolean",
          "default": false,
          "description": "Per-repo allow required before any run may use the full access profile."
        },
        "repo_root": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Provenance only: repo root this trust file was written for; never gates anything. Null on legacy files written before this field."
        },
        "test_command_grants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "projectDigest": {
                "type": "string",
                "minLength": 1,
                "description": "Digest of the canonical project identity."
              },
              "configDigest": {
                "type": "string",
                "minLength": 1,
                "description": "Digest of the parsed versioned project config blob."
              },
              "commandDigest": {
                "type": "string",
                "minLength": 1,
                "description": "Digest of the canonical command invocation."
              },
              "executablePath": {
                "type": "string",
                "description": "Resolved executable path approved by the operator."
              },
              "executableDigest": {
                "type": "string",
                "minLength": 1,
                "description": "Digest of the resolved executable bytes."
              },
              "scriptPath": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Resolved script path, when any."
              },
              "scriptDigest": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1,
                    "description": "Content hash in algo:hex form, e.g. \"sha256:abcd...\"."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Digest of the script bytes.",
                "default": null
              },
              "accessProfile": {
                "type": "string",
                "enum": [
                  "readonly",
                  "workspace_write",
                  "full",
                  "external_sandbox_full",
                  "inherit_native"
                ],
                "description": "Effective access profile covered by this grant."
              }
            },
            "required": [
              "projectDigest",
              "configDigest",
              "commandDigest",
              "executablePath",
              "executableDigest",
              "accessProfile"
            ],
            "additionalProperties": false,
            "description": "External exact grant for one versioned project test command."
          },
          "default": [],
          "description": "External exact grants for versioned project test commands."
        }
      },
      "additionalProperties": false,
      "description": "Sensitive per-repo trust settings — only valid in global/user-local trust files, never in the versioned repo config."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
