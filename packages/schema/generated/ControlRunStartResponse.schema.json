{
  "$ref": "#/definitions/ControlRunStartResponse",
  "definitions": {
    "ControlRunStartResponse": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "jobId": {
              "type": "string",
              "description": "Daemon job id backing the run."
            },
            "runId": {
              "type": "string",
              "description": "Run id."
            },
            "taskId": {
              "type": "string",
              "description": "Task id, when already allocated."
            },
            "runDir": {
              "type": "string",
              "description": "On-disk run artifact directory."
            }
          },
          "required": [
            "runId",
            "runDir"
          ],
          "additionalProperties": false,
          "description": "Response for a successfully enqueued run."
        },
        {
          "type": "object",
          "properties": {
            "jobId": {
              "type": "string",
              "description": "Daemon job id."
            },
            "state": {
              "type": "string",
              "enum": [
                "queued",
                "running",
                "succeeded",
                "failed",
                "cancelled",
                "interrupted"
              ],
              "description": "Control-plane run state = the run LIFECYCLE (D8): queued/running while live, then exactly one of succeeded / failed / cancelled / interrupted. Outcome quality (checks/review/delivery) is orthogonal — see outcomeFacts."
            },
            "error": {
              "type": "string",
              "description": "Error message, when the job failed."
            }
          },
          "required": [
            "jobId",
            "state"
          ],
          "additionalProperties": false,
          "description": "Compact state of a queued/running daemon job."
        }
      ],
      "description": "Immediate or queued durable handle returned by POST /runs."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
