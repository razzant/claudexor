{
  "$ref": "#/definitions/ConformanceReport",
  "definitions": {
    "ConformanceReport": {
      "type": "object",
      "properties": {
        "harness_id": {
          "type": "string",
          "minLength": 1,
          "description": "Harness the report is about."
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "degraded",
            "unavailable"
          ],
          "description": "Doctor verdict for a harness: ok (usable), degraded (usable with limitations), or unavailable."
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Check id."
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "skip"
                ],
                "description": "Outcome of the check: pass, fail, or skip."
              },
              "detail": {
                "type": "string",
                "description": "Human-readable detail for the outcome."
              },
              "duration_ms": {
                "type": "integer",
                "minimum": 0,
                "description": "How long the check took, in milliseconds."
              }
            },
            "required": [
              "id",
              "status"
            ],
            "additionalProperties": false,
            "description": "Result of a conformance probe for one capability check."
          },
          "default": [],
          "description": "Individual probe results."
        },
        "enabled_intents": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "plan",
              "spec",
              "implement",
              "create_from_scratch",
              "repair",
              "review",
              "verify",
              "synthesize",
              "explain",
              "audit"
            ],
            "description": "Canonical intent a harness can be assigned for a session (roles are intents, never fixed classes)."
          },
          "default": [],
          "description": "Intents the gateway will route to this harness."
        },
        "disabled_intents": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ConformanceReport/properties/enabled_intents/items"
          },
          "default": [],
          "description": "Intents the doctor disabled."
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Human-readable reasons for degraded/unavailable status or disabled intents."
        },
        "auth_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "native_session",
                  "oauth_token_env",
                  "api_key_env",
                  "api_key_flag",
                  "provider_auth_file",
                  "none"
                ],
                "description": "Concrete credential source used or probed by a harness."
              },
              "availability": {
                "type": "string",
                "enum": [
                  "available",
                  "unavailable",
                  "unknown"
                ]
              },
              "verification": {
                "type": "string",
                "enum": [
                  "passed",
                  "failed",
                  "not_run"
                ]
              },
              "detail": {
                "type": "string",
                "description": "Redacted human-readable source evidence."
              }
            },
            "required": [
              "source",
              "availability",
              "verification"
            ],
            "additionalProperties": false,
            "description": "Doctor-backed readiness for one exact credential source."
          },
          "default": [],
          "description": "Doctor-backed readiness by authentication source; an empty array means the adapter did not report source readiness."
        }
      },
      "required": [
        "harness_id",
        "status"
      ],
      "additionalProperties": false,
      "description": "Doctor/conformance report for one harness: status, probe results, and the intents enabled or disabled by it."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
