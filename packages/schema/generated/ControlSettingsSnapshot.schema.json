{
  "$ref": "#/definitions/ControlSettingsSnapshot",
  "definitions": {
    "ControlSettingsSnapshot": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "defaultPortfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ],
          "default": "subscription-first"
        },
        "interactionTimeoutMs": {
          "type": "integer",
          "exclusiveMinimum": true,
          "minimum": 0,
          "default": 900000
        },
        "routing": {
          "type": "object",
          "properties": {
            "defaultPolicy": {
              "type": "string",
              "enum": [
                "auto",
                "primary",
                "portfolio"
              ],
              "default": "auto"
            },
            "primaryHarness": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "eligibleHarnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "defaultModel": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "envInheritance": {
              "type": "string",
              "enum": [
                "mirror_native",
                "clean",
                "profile_only"
              ],
              "default": "mirror_native"
            },
            "authPreference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "default": "auto"
            },
            "fallback": {
              "type": "object",
              "properties": {
                "onQuotaExhaustion": {
                  "type": "string",
                  "enum": [
                    "subscription_to_api",
                    "harness_to_harness",
                    "both",
                    "off"
                  ],
                  "default": "both"
                },
                "onMoneyExhaustion": {
                  "$ref": "#/definitions/ControlSettingsSnapshot/properties/routing/properties/fallback/properties/onQuotaExhaustion",
                  "default": "both"
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "budget": {
          "type": "object",
          "properties": {
            "maxUsdPerRun": {
              "type": [
                "number",
                "null"
              ],
              "default": null
            },
            "maxUsdPerDay": {
              "type": [
                "number",
                "null"
              ],
              "default": null
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "defaultModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "effort": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "xhigh",
                      "max"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "maxTurns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "maxRounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "maxUsd": {
                "anyOf": [
                  {
                    "type": "number",
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "toolsAllow": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "toolsDeny": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "fallbackModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ],
                "default": "auto"
              },
              "nativeOptions": {
                "type": "object",
                "additionalProperties": {},
                "default": {}
              },
              "authPreference": {
                "$ref": "#/definitions/ControlSettingsSnapshot/properties/routing/properties/authPreference",
                "default": "auto"
              }
            },
            "additionalProperties": false
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  }
}
