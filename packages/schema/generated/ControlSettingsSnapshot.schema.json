{
  "$ref": "#/definitions/ControlSettingsSnapshot",
  "definitions": {
    "ControlSettingsSnapshot": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Config file paths that contributed to the snapshot."
        },
        "interactionTimeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 900000,
          "description": "How long a run waits for an interactive answer before a benign decline, in milliseconds."
        },
        "routing": {
          "type": "object",
          "properties": {
            "primaryHarness": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Global default primary harness; null = engine decides."
            },
            "eligibleHarnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Harness pool eligible for routing/races; empty = all available."
            },
            "envInheritance": {
              "type": "string",
              "enum": [
                "mirror_native",
                "clean"
              ],
              "default": "mirror_native",
              "description": "How the child harness env is built: mirror_native inherits the shell env; clean spawns from a minimal allowlist."
            },
            "authPreference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret.",
              "default": "auto"
            },
            "goal": {
              "type": "string",
              "enum": [
                "auto",
                "quality",
                "economy"
              ],
              "description": "Routing objective: pace expiring quota, choose the highest declared quality tier, or minimize incremental paid spend.",
              "default": "auto"
            },
            "paidFallback": {
              "type": "string",
              "enum": [
                "never",
                "when_unavailable",
                "allowed_within_cap"
              ],
              "description": "When a route with incremental paid spend may be used.",
              "default": "when_unavailable"
            },
            "qualityTiers": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "harness": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Non-empty identifier string."
                      },
                      "model": {
                        "type": "string",
                        "minLength": 1
                      },
                      "effort": {
                        "type": "string",
                        "enum": [
                          "low",
                          "medium",
                          "high",
                          "xhigh",
                          "max"
                        ],
                        "description": "Cross-harness reasoning-effort level, weakest to strongest; adapters declare the subset they support and a shared normalizer clamps requests onto the nearest supported level."
                      }
                    },
                    "required": [
                      "harness",
                      "model",
                      "effort"
                    ],
                    "additionalProperties": false,
                    "description": "An exact harness, model, and effort route declared by the user."
                  },
                  "minItems": 1,
                  "description": "A group of comparable exact routes at one user-declared quality level."
                }
              },
              "propertyNames": {
                "enum": [
                  "plan",
                  "spec",
                  "implement",
                  "create_from_scratch",
                  "repair",
                  "review",
                  "verify",
                  "synthesize",
                  "explain",
                  "audit"
                ]
              },
              "default": {},
              "description": "Per-intent quality tiers ordered highest to lowest; no provider or benchmark priors are inferred."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global routing settings."
        },
        "budget": {
          "type": "object",
          "properties": {
            "paidBudgetPerRun": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "unlimited"
                    }
                  },
                  "required": [
                    "kind"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "finite"
                    },
                    "maxUsd": {
                      "type": "number",
                      "minimum": 0
                    }
                  },
                  "required": [
                    "kind",
                    "maxUsd"
                  ],
                  "additionalProperties": false
                }
              ],
              "description": "Incremental-cash budget: explicitly unlimited or a finite non-negative USD cap.",
              "default": {
                "kind": "unlimited"
              }
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global budget limits."
        },
        "runtime": {
          "type": "object",
          "properties": {
            "reviewerTimeoutMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 600000,
              "description": "Wall-clock timeout for a reviewer run, in milliseconds."
            },
            "harnessInactivityTimeoutMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 1200000,
              "description": "Inactivity watchdog for harness streams, in milliseconds."
            },
            "transientRetry": {
              "type": "object",
              "properties": {
                "maxRetries": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 2,
                  "description": "Maximum retries for a transient failure."
                },
                "initialDelayMs": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 1000,
                  "description": "Initial retry delay in milliseconds."
                },
                "maxDelayMs": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10000,
                  "description": "Maximum retry delay in milliseconds."
                }
              },
              "additionalProperties": false,
              "default": {},
              "description": "Bounded retry policy for transient failures."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global runtime timeouts and retry policy."
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether the harness participates in routing."
              },
              "activeProfileId": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Active credential profile id for new runs/turns of this harness; null = the native/CLI login."
              },
              "nativeCredentialsEnabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether the native/CLI login participates in this harness's credential ladder."
              },
              "defaultModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Per-harness default model; null = the harness's own default."
              },
              "effort": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlSettingsSnapshot/properties/routing/properties/qualityTiers/additionalProperties/items/items/properties/effort"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Default reasoning effort; null = harness default.",
                "default": null
              },
              "maxTurns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Default max agent turns; null = no limit."
              },
              "maxRounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Default max convergence rounds; null = engine default."
              },
              "toolsAllow": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Tool names allowed for this harness."
              },
              "toolsDeny": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Tool names denied for this harness."
              },
              "fallbackModel": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model to fall back to on typed fallback signals; null = none."
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ],
                "description": "Default web policy for this harness.",
                "default": "auto"
              },
              "authPreference": {
                "$ref": "#/definitions/ControlSettingsSnapshot/properties/routing/properties/authPreference",
                "default": "auto",
                "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret."
              },
              "profileLimitAction": {
                "type": "string",
                "enum": [
                  "fail",
                  "ask",
                  "rotate"
                ],
                "default": "fail",
                "description": "Profile-selection limit action: fail (stop), ask (record), rotate (auto-switch to the next eligible account)."
              }
            },
            "additionalProperties": false,
            "description": "Per-harness settings."
          },
          "default": {},
          "description": "Per-harness settings keyed by harness id."
        }
      },
      "additionalProperties": false,
      "description": "Effective settings snapshot served by GET /settings."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
