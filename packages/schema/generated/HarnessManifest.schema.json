{
  "$ref": "#/definitions/HarnessManifest",
  "definitions": {
    "HarnessManifest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "local_cli",
            "local_server",
            "sdk",
            "remote_api",
            "external_adapter",
            "fake"
          ]
        },
        "version": {
          "type": "string"
        },
        "adapter_version": {
          "type": "string"
        },
        "provider_family": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "google",
            "cursor",
            "opencode",
            "xai",
            "local",
            "unknown"
          ],
          "default": "unknown"
        },
        "capability_profile": {
          "type": "object",
          "properties": {
            "execution_surfaces": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "cli_one_shot",
                      "stdin_stream_session",
                      "background_session",
                      "local_http_server",
                      "acp_stdio_jsonrpc"
                    ]
                  },
                  "input": {
                    "type": "string",
                    "enum": [
                      "prompt_arg",
                      "stdin_once",
                      "stdin_stream",
                      "json_rpc",
                      "http"
                    ],
                    "default": "prompt_arg"
                  },
                  "output": {
                    "type": "string",
                    "enum": [
                      "text",
                      "json",
                      "ndjson",
                      "sse",
                      "json_rpc"
                    ],
                    "default": "text"
                  },
                  "event_schema": {
                    "type": "string",
                    "enum": [
                      "none",
                      "native",
                      "normalized",
                      "versioned"
                    ],
                    "default": "none"
                  },
                  "supports_followup": {
                    "type": "boolean",
                    "default": false
                  },
                  "supports_interrupt": {
                    "type": "boolean",
                    "default": false
                  },
                  "supports_permission_reply": {
                    "type": "boolean",
                    "default": false
                  }
                },
                "required": [
                  "kind"
                ],
                "additionalProperties": false
              },
              "default": []
            },
            "session": {
              "type": "object",
              "properties": {
                "native_session_id_emitted": {
                  "type": "boolean",
                  "default": false
                },
                "resume_latest": {
                  "type": "boolean",
                  "default": false
                },
                "resume_by_id": {
                  "type": "boolean",
                  "default": false
                },
                "fork": {
                  "type": "boolean",
                  "default": false
                },
                "list": {
                  "type": "boolean",
                  "default": false
                },
                "logs": {
                  "type": "boolean",
                  "default": false
                },
                "attach_tui": {
                  "type": "boolean",
                  "default": false
                },
                "export": {
                  "type": "boolean",
                  "default": false
                },
                "diff": {
                  "type": "boolean",
                  "default": false
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "output": {
              "type": "object",
              "properties": {
                "ndjson_events": {
                  "type": "boolean",
                  "default": false
                },
                "partial_deltas": {
                  "type": "boolean",
                  "default": false
                },
                "tool_lifecycle": {
                  "type": "boolean",
                  "default": false
                },
                "file_changes": {
                  "type": "boolean",
                  "default": false
                },
                "final_json": {
                  "type": "boolean",
                  "default": false
                },
                "json_schema_final": {
                  "type": "boolean",
                  "default": false
                },
                "usage_signal": {
                  "type": "string",
                  "enum": [
                    "exact",
                    "native",
                    "observed",
                    "manual",
                    "unknown"
                  ],
                  "default": "unknown"
                },
                "cost_signal": {
                  "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/output/properties/usage_signal",
                  "default": "unknown"
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "auth": {
              "type": "object",
              "properties": {
                "supported_sources": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "native_session",
                      "browser_login",
                      "api_key_env",
                      "api_key_flag",
                      "provider_auth_file",
                      "project_env",
                      "none"
                    ]
                  },
                  "default": []
                },
                "preferred_source": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/auth/properties/supported_sources/items"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null
                },
                "probe_command": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "env_vars": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "can_scrub_env": {
                  "type": "boolean",
                  "default": true
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "access_control": {
              "type": "object",
              "properties": {
                "readonly": {
                  "type": "boolean",
                  "default": false
                },
                "workspace_write": {
                  "type": "boolean",
                  "default": false
                },
                "full": {
                  "type": "boolean",
                  "default": false
                },
                "mechanism": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "conformance_required": {
                  "type": "boolean",
                  "default": true
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "plan": {
              "type": "boolean",
              "default": false
            },
            "spec": {
              "type": "boolean",
              "default": false
            },
            "implement": {
              "type": "boolean",
              "default": false
            },
            "create_from_scratch": {
              "type": "boolean",
              "default": false
            },
            "repair": {
              "type": "boolean",
              "default": false
            },
            "review": {
              "type": "boolean",
              "default": false
            },
            "verify": {
              "type": "boolean",
              "default": false
            },
            "compare": {
              "type": "boolean",
              "default": false
            },
            "synthesize": {
              "type": "boolean",
              "default": false
            },
            "shell": {
              "type": "boolean",
              "default": false
            },
            "read_files": {
              "type": "boolean",
              "default": false
            },
            "edit_files": {
              "type": "boolean",
              "default": false
            },
            "apply_patch": {
              "type": "boolean",
              "default": false
            },
            "structured_events": {
              "type": "boolean",
              "default": false
            },
            "structured_output": {
              "type": "boolean",
              "default": false
            },
            "json_schema_output": {
              "type": "boolean",
              "default": false
            },
            "resume": {
              "type": "boolean",
              "default": false
            },
            "cancel": {
              "type": "boolean",
              "default": false
            },
            "mcp": {
              "type": "boolean",
              "default": false
            },
            "plugins": {
              "type": "boolean",
              "default": false
            },
            "worktree_native": {
              "type": "boolean",
              "default": false
            },
            "quota_signal": {
              "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/output/properties/usage_signal",
              "default": "unknown"
            },
            "usage_signal": {
              "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/output/properties/usage_signal",
              "default": "unknown"
            }
          },
          "additionalProperties": false
        },
        "auth_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "local_session",
              "api_key",
              "none"
            ]
          },
          "default": []
        },
        "access_profiles_supported": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "readonly",
              "workspace_write",
              "full",
              "external_sandbox_full",
              "inherit_native"
            ]
          },
          "default": []
        },
        "models": {
          "type": "object",
          "properties": {
            "discovery": {
              "type": "string",
              "enum": [
                "available",
                "unavailable",
                "experimental"
              ],
              "default": "unavailable"
            }
          },
          "additionalProperties": false,
          "default": {
            "discovery": "unavailable"
          }
        }
      },
      "required": [
        "id",
        "display_name",
        "kind",
        "capabilities"
      ],
      "additionalProperties": false
    }
  }
}
