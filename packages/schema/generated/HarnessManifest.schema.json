{
  "$ref": "#/definitions/HarnessManifest",
  "definitions": {
    "HarnessManifest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "local_cli",
            "local_server",
            "sdk",
            "remote_api",
            "external_adapter",
            "fake"
          ]
        },
        "version": {
          "type": "string"
        },
        "adapter_version": {
          "type": "string"
        },
        "provider_family": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "google",
            "cursor",
            "opencode",
            "xai",
            "local",
            "unknown"
          ],
          "default": "unknown"
        },
        "capability_profile": {
          "type": "object",
          "properties": {
            "auth": {
              "type": "object",
              "properties": {
                "supported_sources": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "native_session",
                      "api_key_env",
                      "api_key_flag",
                      "provider_auth_file",
                      "none"
                    ]
                  },
                  "default": []
                },
                "preferred_source": {
                  "anyOf": [
                    {
                      "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/auth/properties/supported_sources/items"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "default": null
                },
                "credential_transports": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "source": {
                        "$ref": "#/definitions/HarnessManifest/properties/capability_profile/properties/auth/properties/supported_sources/items"
                      },
                      "kind": {
                        "type": "string",
                        "enum": [
                          "config_file",
                          "env_var",
                          "oauth_token_env",
                          "os_keychain",
                          "http_header",
                          "none"
                        ]
                      },
                      "relocatable_by": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": [
                            "HOME",
                            "CONFIG_DIR",
                            "ENV",
                            "none"
                          ]
                        },
                        "default": []
                      }
                    },
                    "required": [
                      "source",
                      "kind"
                    ],
                    "additionalProperties": false
                  },
                  "default": []
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "access_control": {
              "type": "object",
              "properties": {
                "readonly_mechanism": {
                  "type": "string",
                  "enum": [
                    "fs_sandbox",
                    "permission_deny",
                    "tool_allowlist",
                    "none"
                  ],
                  "default": "none"
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "isolation": {
              "type": "object",
              "properties": {
                "supported_containment": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "env_or_file_injection",
                      "scoped_home_keychain_bridge",
                      "host_user_context",
                      "process_sandbox",
                      "container"
                    ]
                  },
                  "default": [
                    "env_or_file_injection"
                  ]
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "image_input": {
              "type": "string",
              "enum": [
                "file_path",
                "base64_stream",
                "base64_inline",
                "none"
              ],
              "default": "none"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "capabilities": {
          "type": "object",
          "properties": {
            "plan": {
              "type": "boolean",
              "default": false
            },
            "implement": {
              "type": "boolean",
              "default": false
            },
            "create_from_scratch": {
              "type": "boolean",
              "default": false
            },
            "review": {
              "type": "boolean",
              "default": false
            },
            "verify": {
              "type": "boolean",
              "default": false
            },
            "synthesize": {
              "type": "boolean",
              "default": false
            },
            "read_files": {
              "type": "boolean",
              "default": false
            },
            "browser_tool": {
              "type": "boolean",
              "default": false
            },
            "web_policy": {
              "type": "string",
              "enum": [
                "native",
                "tools",
                "uncontrolled",
                "none"
              ],
              "default": "none"
            },
            "max_turns": {
              "type": "boolean",
              "default": false
            },
            "tool_lists": {
              "type": "boolean",
              "default": false
            },
            "interactive": {
              "type": "boolean",
              "default": false
            },
            "orchestrate": {
              "type": "boolean",
              "default": false
            },
            "quota_signal": {
              "type": "string",
              "enum": [
                "exact",
                "native",
                "observed",
                "manual",
                "unknown"
              ],
              "default": "unknown"
            },
            "usage_signal": {
              "$ref": "#/definitions/HarnessManifest/properties/capabilities/properties/quota_signal",
              "default": "unknown"
            },
            "effort_levels": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "xhigh",
                  "max"
                ]
              },
              "default": []
            },
            "known_models": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "known_models_verified_against": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            }
          },
          "additionalProperties": false
        },
        "auth_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "local_session",
              "api_key",
              "none"
            ]
          },
          "default": []
        },
        "access_profiles_supported": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "readonly",
              "workspace_write",
              "full",
              "external_sandbox_full",
              "inherit_native"
            ]
          },
          "default": []
        }
      },
      "required": [
        "id",
        "display_name",
        "kind",
        "capabilities"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
