{
  "$ref": "#/definitions/ControlSpecQuestionsRequest",
  "definitions": {
    "ControlSpecQuestionsRequest": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string"
        },
        "scope": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "project"
            },
            "root": {
              "type": "string"
            },
            "context": {
              "type": "string",
              "enum": [
                "auto",
                "deep"
              ],
              "default": "auto"
            }
          },
          "required": [
            "kind",
            "root"
          ],
          "additionalProperties": false
        },
        "harnesses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "priorDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "prompt",
        "scope"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
