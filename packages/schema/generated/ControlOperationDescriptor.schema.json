{
  "$ref": "#/definitions/ControlOperationDescriptor",
  "definitions": {
    "ControlOperationDescriptor": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^\\/v2\\/"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "One-line human summary of the operation."
        },
        "auth": {
          "type": "string",
          "enum": [
            "loopback_bearer",
            "loopback_only"
          ],
          "description": "Auth boundary: loopback + bearer token, or loopback-only."
        },
        "requestSchema": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Wire name of the parameter: the query key or the (case-insensitive) header field name."
              },
              "location": {
                "type": "string",
                "enum": [
                  "query",
                  "header"
                ],
                "description": "Where the parameter travels: the URL query string or a request header."
              },
              "required": {
                "type": "boolean",
                "description": "Whether the operation requires the parameter to be present."
              },
              "repeatable": {
                "type": "boolean",
                "default": false,
                "description": "Whether the parameter may appear more than once (e.g. a repeated query filter)."
              },
              "enum": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Closed set of accepted values when the grammar is a fixed enum; null otherwise."
              },
              "schemaRef": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Generated schema name (optionally a `Name#/properties/field` pointer) that types this parameter's value when it is not a simple enum; null otherwise."
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "One-line human semantics of the parameter."
              }
            },
            "required": [
              "name",
              "location",
              "required",
              "description"
            ],
            "additionalProperties": false,
            "description": "A query or header request parameter an operation reads (never the JSON body)."
          },
          "default": [],
          "description": "Query/header request parameters (body shape is `requestSchema`)."
        },
        "responseSchema": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "errorSchema": {
          "type": "string",
          "const": "ControlProblem"
        },
        "mutability": {
          "type": "string",
          "enum": [
            "read_only",
            "mutating"
          ]
        },
        "idempotency": {
          "type": "string",
          "enum": [
            "none",
            "natural",
            "key_required"
          ]
        },
        "applicability": {
          "type": "string",
          "enum": [
            "global",
            "project",
            "thread",
            "run"
          ]
        },
        "responseKind": {
          "type": "string",
          "enum": [
            "json",
            "stream",
            "binary"
          ]
        },
        "completion": {
          "type": "string",
          "enum": [
            "immediate",
            "durable_handle",
            "terminal_stream"
          ]
        }
      },
      "required": [
        "id",
        "method",
        "path",
        "summary",
        "auth",
        "requestSchema",
        "responseSchema",
        "errorSchema",
        "mutability",
        "idempotency",
        "applicability",
        "responseKind",
        "completion"
      ],
      "additionalProperties": false,
      "description": "Machine-readable truth for one implemented v2 operation."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
