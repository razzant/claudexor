{
  "$ref": "#/definitions/BudgetLease",
  "definitions": {
    "BudgetLease": {
      "type": "object",
      "properties": {
        "lease_id": {
          "type": "string",
          "minLength": 1,
          "description": "Lease id."
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "description": "Task the lease belongs to."
        },
        "attempt_id": {
          "type": "string",
          "minLength": 1,
          "description": "Attempt the lease covers, when scoped to one."
        },
        "intent": {
          "type": "string",
          "enum": [
            "plan",
            "spec",
            "implement",
            "create_from_scratch",
            "repair",
            "review",
            "verify",
            "synthesize",
            "explain",
            "audit",
            "orchestrate"
          ],
          "description": "Canonical intent a harness can be assigned for a session (roles are intents, never fixed classes)."
        },
        "harness_id": {
          "type": "string",
          "minLength": 1,
          "description": "Harness the reservation is for."
        },
        "model_hint": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Requested model for the reserved call; null = harness default."
        },
        "max_usd": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "USD cap reserved for the call; null = no cap."
        },
        "reason": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Human-readable reasons the lease was created."
        },
        "created_at": {
          "type": "string",
          "description": "When the lease was created."
        },
        "state": {
          "type": "string",
          "enum": [
            "reserved",
            "settled",
            "cancelled"
          ],
          "default": "reserved",
          "description": "Lifecycle state: reserved before work, settled after, or cancelled."
        }
      },
      "required": [
        "lease_id",
        "task_id",
        "intent",
        "harness_id",
        "created_at"
      ],
      "additionalProperties": false,
      "description": "A pre-call budget reservation, created before work and settled after; never post-hoc only."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
