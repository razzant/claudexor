{
  "$ref": "#/definitions/BudgetLease",
  "definitions": {
    "BudgetLease": {
      "type": "object",
      "properties": {
        "lease_id": {
          "type": "string",
          "minLength": 1,
          "description": "Lease id."
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "description": "Task the lease belongs to."
        },
        "attempt_id": {
          "type": "string",
          "minLength": 1,
          "description": "Attempt the lease covers, when scoped to one."
        },
        "intent": {
          "type": "string",
          "enum": [
            "plan",
            "spec",
            "implement",
            "create_from_scratch",
            "repair",
            "review",
            "verify",
            "synthesize",
            "explain",
            "audit",
            "orchestrate"
          ],
          "description": "Canonical intent a harness can be assigned for a session (roles are intents, never fixed classes)."
        },
        "harness_id": {
          "type": "string",
          "minLength": 1,
          "description": "Harness the reservation is for."
        },
        "model_hint": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Requested model for the reserved call; null = harness default."
        },
        "cost": {
          "type": "object",
          "properties": {
            "knowledge": {
              "type": "string",
              "enum": [
                "exact",
                "estimated",
                "unknown"
              ],
              "description": "Quality of incremental-cash cost evidence for an operation."
            },
            "billing": {
              "type": "string",
              "enum": [
                "proven_zero",
                "subscription_entitlement",
                "metered",
                "unknown"
              ],
              "description": "What is actually known about incremental billing; a native credential route alone never proves entitlement or zero cost."
            },
            "source": {
              "type": "string",
              "minLength": 1
            },
            "provenance": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "estimatedUsd": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "required": [
            "knowledge",
            "billing",
            "source",
            "provenance"
          ],
          "additionalProperties": false,
          "description": "Incremental-cash cost knowledge with its source and evidence provenance."
        },
        "reason": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Human-readable reasons the lease was created."
        },
        "created_at": {
          "type": "string",
          "description": "When the lease was created."
        },
        "state": {
          "type": "string",
          "enum": [
            "reserved",
            "settled",
            "cancelled"
          ],
          "default": "reserved",
          "description": "Lifecycle state: reserved before work, settled after, or cancelled."
        }
      },
      "required": [
        "lease_id",
        "task_id",
        "intent",
        "harness_id",
        "cost",
        "created_at"
      ],
      "additionalProperties": false,
      "description": "A pre-call budget reservation, created before work and settled after; never post-hoc only."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
