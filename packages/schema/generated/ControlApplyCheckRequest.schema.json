{
  "$ref": "#/definitions/ControlApplyCheckRequest",
  "definitions": {
    "ControlApplyCheckRequest": {
      "type": "object",
      "properties": {
        "target": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "original_project"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "description": "Apply to the project the run originally came from."
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string",
                  "description": "Absolute path of the target project root."
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false,
              "description": "Apply to an explicitly named project root."
            }
          ],
          "description": "Where a work product is delivered: the original project or an explicit project root.",
          "default": {
            "kind": "original_project"
          }
        }
      },
      "additionalProperties": false,
      "description": "Request body for a dry-run apply check."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
