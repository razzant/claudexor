{
  "$ref": "#/definitions/ControlCredentialProfileCreateRequest",
  "definitions": {
    "ControlCredentialProfileCreateRequest": {
      "type": "object",
      "properties": {
        "harnessId": {
          "type": "string",
          "minLength": 1,
          "description": "Harness family (claude | codex) for the config-dir login profile."
        },
        "profileId": {
          "type": "string",
          "minLength": 1,
          "description": "New profile id (bounded slug, unique per harness)."
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "description": "Human label shown wherever the account appears; defaults to the id."
        }
      },
      "required": [
        "harnessId",
        "profileId"
      ],
      "additionalProperties": false,
      "description": "Request body for POST /credential-profiles."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
