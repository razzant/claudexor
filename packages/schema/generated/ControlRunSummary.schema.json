{
  "$ref": "#/definitions/ControlRunSummary",
  "definitions": {
    "ControlRunSummary": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "blocked",
            "succeeded",
            "no_op",
            "ungated",
            "review_not_run",
            "failed",
            "cancelled",
            "interrupted",
            "exhausted",
            "not_converged",
            "stuck_no_progress"
          ]
        },
        "runDir": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "failure": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "phase": {
                  "type": "string",
                  "default": "unknown"
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "validation",
                    "project",
                    "auth",
                    "harness_unavailable",
                    "harness_error",
                    "budget",
                    "policy",
                    "cancelled",
                    "internal",
                    "unknown"
                  ],
                  "default": "unknown"
                },
                "harnessId": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "attemptId": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "safeMessage": {
                  "type": "string"
                },
                "rawDetailRef": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "logRefs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "eventRefs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "runDir": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "nextActions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              },
              "required": [
                "safeMessage"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "project": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "project",
                "none"
              ],
              "default": "none"
            },
            "root": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "projectName": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "context": {
              "type": "string",
              "enum": [
                "off",
                "auto",
                "deep"
              ],
              "default": "off"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "plan",
            "audit",
            "agent",
            "orchestrate"
          ]
        },
        "strategy": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "race",
                "attempts",
                "until_clean",
                "swarm",
                "create"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "prompt": {
          "type": "string"
        },
        "harnesses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryHarness": {
          "type": "string"
        },
        "portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "model": {
          "type": "string"
        },
        "reviewerPanel": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "harness": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "model": {
                "$ref": "#/definitions/ControlRunSummary/properties/reviewerPanel/items/properties/harness"
              },
              "effort": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "xhigh",
                  "max"
                ]
              }
            },
            "required": [
              "harness"
            ],
            "additionalProperties": false
          }
        },
        "protectedPathApprovals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "$ref": "#/definitions/ControlRunSummary/properties/reviewerPanel/items/properties/harness"
              },
              "reason": {
                "$ref": "#/definitions/ControlRunSummary/properties/reviewerPanel/items/properties/harness"
              }
            },
            "required": [
              "path"
            ],
            "additionalProperties": false
          }
        },
        "n": {
          "type": "integer"
        },
        "maxUsd": {
          "type": [
            "number",
            "null"
          ]
        },
        "spendUsd": {
          "type": [
            "number",
            "null"
          ]
        },
        "spendEstimated": {
          "type": "boolean"
        },
        "access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ]
        },
        "requestedAccess": {
          "$ref": "#/definitions/ControlRunSummary/properties/access"
        },
        "effectiveAccess": {
          "$ref": "#/definitions/ControlRunSummary/properties/access"
        },
        "externalContextPolicy": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "cached",
            "live"
          ]
        },
        "webRequired": {
          "type": "boolean"
        },
        "webMode": {
          "$ref": "#/definitions/ControlRunSummary/properties/externalContextPolicy"
        },
        "webEvidence": {
          "type": "object",
          "properties": {
            "required": {
              "type": "boolean",
              "default": false
            },
            "mode": {
              "$ref": "#/definitions/ControlRunSummary/properties/externalContextPolicy",
              "default": "auto"
            },
            "effectiveMode": {
              "$ref": "#/definitions/ControlRunSummary/properties/externalContextPolicy",
              "default": "auto"
            },
            "attempted": {
              "type": "boolean",
              "default": false
            },
            "satisfied": {
              "type": "boolean",
              "default": false
            },
            "status": {
              "type": "string",
              "enum": [
                "none",
                "attempted",
                "satisfied",
                "failed",
                "unverified"
              ],
              "default": "none"
            },
            "tool": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "target": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "errorSummary": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "rawDetailRef": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "available": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "toolPermissionPolicy": {
          "type": "object",
          "additionalProperties": {}
        },
        "outputReadyState": {
          "type": "string",
          "enum": [
            "pending",
            "finalizing",
            "ready",
            "diagnostic"
          ],
          "default": "pending"
        },
        "toolWarningsTotal": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "result": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "patch",
                "answer",
                "plan",
                "report",
                "none"
              ],
              "default": "none"
            },
            "diffStat": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "files": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "additions": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "deletions": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "required": [
                    "files",
                    "additions",
                    "deletions"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "blockers": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "adopted": {
              "type": [
                "boolean",
                "null"
              ],
              "default": null
            },
            "applyState": {
              "type": "string",
              "enum": [
                "not_applied",
                "applied",
                "applied_review_blocked",
                "reverted"
              ],
              "default": "not_applied"
            },
            "preTurnSha": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "postTurnSha": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "revertable": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "waitingOnUser": {
          "type": "boolean",
          "default": false
        },
        "route": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "requestedModel": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "observedModel": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "harnessId": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "verified": {
                  "type": "boolean",
                  "default": false
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specId": {
          "type": "string"
        },
        "specHash": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string"
        },
        "startedAt": {
          "type": "string"
        },
        "finishedAt": {
          "type": "string"
        }
      },
      "required": [
        "jobId",
        "runId",
        "state"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
