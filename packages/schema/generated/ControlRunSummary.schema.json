{
  "$ref": "#/definitions/ControlRunSummary",
  "definitions": {
    "ControlRunSummary": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "blocked",
            "succeeded",
            "no_op",
            "ungated",
            "review_not_run",
            "failed",
            "cancelled",
            "interrupted",
            "exhausted",
            "not_converged"
          ]
        },
        "runDir": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "failure": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "phase": {
                  "type": "string",
                  "default": "unknown"
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "validation",
                    "project",
                    "auth",
                    "harness_unavailable",
                    "harness_error",
                    "budget",
                    "policy",
                    "cancelled",
                    "internal",
                    "unknown"
                  ],
                  "default": "unknown"
                },
                "harnessId": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "attemptId": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "safeMessage": {
                  "type": "string"
                },
                "rawDetailRef": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "logRefs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "eventRefs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                },
                "runDir": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null
                },
                "nextActions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              },
              "required": [
                "safeMessage"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "project": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "project",
                "none"
              ],
              "default": "none"
            },
            "root": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "projectName": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "context": {
              "type": "string",
              "enum": [
                "off",
                "auto",
                "deep"
              ],
              "default": "off"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "explore",
            "agent",
            "best_of_n",
            "max_attempts",
            "until_clean",
            "plan",
            "create",
            "readonly_audit"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "harnesses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryHarness": {
          "type": "string"
        },
        "portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "model": {
          "type": "string"
        },
        "n": {
          "type": "integer"
        },
        "maxUsd": {
          "type": [
            "number",
            "null"
          ]
        },
        "spendUsd": {
          "type": [
            "number",
            "null"
          ]
        },
        "spendEstimated": {
          "type": "boolean"
        },
        "access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ]
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specId": {
          "type": "string"
        },
        "specHash": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string"
        },
        "startedAt": {
          "type": "string"
        },
        "finishedAt": {
          "type": "string"
        }
      },
      "required": [
        "jobId",
        "runId",
        "state"
      ],
      "additionalProperties": false
    }
  }
}
