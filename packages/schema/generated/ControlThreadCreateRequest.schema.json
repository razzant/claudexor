{
  "$ref": "#/definitions/ControlThreadCreateRequest",
  "definitions": {
    "ControlThreadCreateRequest": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Initial thread title."
        },
        "scope": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string",
                  "description": "Absolute path of the project root."
                },
                "context": {
                  "type": "string",
                  "enum": [
                    "auto"
                  ],
                  "description": "Project context depth; auto is the only mode.",
                  "default": "auto"
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false,
              "description": "Run anchored to a project."
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "none"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "description": "Run with no project (pure ask)."
            }
          ],
          "description": "What the run operates on: a project (with root) or nothing.",
          "default": {
            "kind": "none"
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "plan",
            "agent"
          ],
          "description": "Default mode for new turns."
        },
        "workspace": {
          "type": "string",
          "enum": [
            "in_place",
            "isolated"
          ],
          "description": "Workspace mode for the thread (in_place or isolated)."
        },
        "authPreference": {
          "type": "string",
          "enum": [
            "subscription",
            "api_key",
            "auto"
          ],
          "description": "Per-thread auth preference override."
        },
        "credentialProfileId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Sticky credential profile for the thread (INV-135); per-turn selection wins."
        },
        "primaryHarness": {
          "$ref": "#/definitions/ControlThreadCreateRequest/properties/credentialProfileId",
          "description": "Sticky primary harness for the thread."
        },
        "eligibleHarnesses": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ControlThreadCreateRequest/properties/credentialProfileId"
          },
          "description": "Sticky eligible harness pool; turns inherit it when unset."
        },
        "access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ],
          "description": "Sticky write scope for the thread's write turns; omit = the repo trust default."
        }
      },
      "additionalProperties": false,
      "description": "Request body for POST /threads."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
