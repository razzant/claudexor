{
  "$ref": "#/definitions/ControlThreadListResponse",
  "definitions": {
    "ControlThreadListResponse": {
      "type": "object",
      "properties": {
        "threads": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Thread id."
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Thread title; null until set."
              },
              "repoRoot": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Project root the thread is anchored to; null for a no-project thread."
              },
              "mode": {
                "type": "string",
                "enum": [
                  "ask",
                  "plan",
                  "agent",
                  "orchestrate"
                ],
                "description": "Default mode for new turns."
              },
              "workspaceMode": {
                "type": "string",
                "enum": [
                  "in_place",
                  "isolated"
                ],
                "description": "Per-thread workspace mode: in_place mutates the live project tree directly (the default); isolated keeps a persistent git worktree per thread that apply merges into the project.",
                "default": "in_place"
              },
              "authPreference": {
                "type": "string",
                "enum": [
                  "subscription",
                  "api_key",
                  "auto"
                ],
                "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret.",
                "default": "auto"
              },
              "primaryHarness": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Sticky primary harness for the thread; null = engine routing."
              },
              "eligibleHarnesses": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Sticky eligible harness pool; empty = the engine auto-pools."
              },
              "credentialProfileId": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1,
                    "description": "Non-empty identifier string."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Sticky credential profile for the thread; per-turn selection wins, null = engine-default credentials.",
                "default": null
              },
              "access": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "readonly",
                      "workspace_write",
                      "full",
                      "external_sandbox_full",
                      "inherit_native"
                    ],
                    "description": "Filesystem/command access profile for a run: readonly (no writes), workspace_write (writes inside the workspace only), full (unrestricted; requires the per-repo trust allow), external_sandbox_full (full access inside an external sandbox), inherit_native (defer to the harness's own native sandbox settings)."
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Sticky write scope for write turns; null = the repo trust default.",
                "default": null
              },
              "state": {
                "type": "string",
                "enum": [
                  "active",
                  "closed",
                  "trashed",
                  "purged"
                ],
                "description": "Thread lifecycle state: active, closed, trashed for recovery, or terminally purged.",
                "default": "active"
              },
              "trashedAt": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "When the thread entered trash."
              },
              "purgeAfter": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "When trash retention expires."
              },
              "runIds": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/ControlThreadListResponse/properties/threads/items/properties/credentialProfileId/anyOf/0"
                },
                "default": [],
                "description": "Ordered run lineage of the thread."
              },
              "headRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadListResponse/properties/threads/items/properties/credentialProfileId/anyOf/0"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Most recent run of the thread; null before the first turn runs.",
                "default": null
              },
              "needsHuman": {
                "type": "boolean",
                "default": false,
                "description": "True when the head turn is blocked on a human decision (needs-me inbox)."
              },
              "createdAt": {
                "type": "string",
                "description": "When the thread was created."
              },
              "updatedAt": {
                "type": "string",
                "description": "When the thread was last updated."
              }
            },
            "required": [
              "id",
              "createdAt",
              "updatedAt"
            ],
            "additionalProperties": false,
            "description": "Control-plane projection of a thread (camelCase view of the Thread artifact)."
          },
          "default": [],
          "description": "All threads."
        }
      },
      "additionalProperties": false,
      "description": "Response for GET /threads."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
