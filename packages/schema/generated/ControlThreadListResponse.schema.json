{
  "$ref": "#/definitions/ControlThreadListResponse",
  "definitions": {
    "ControlThreadListResponse": {
      "type": "object",
      "properties": {
        "threads": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "repoRoot": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "mode": {
                "type": "string",
                "enum": [
                  "ask",
                  "plan",
                  "audit",
                  "agent",
                  "orchestrate"
                ]
              },
              "workspaceMode": {
                "type": "string",
                "enum": [
                  "in_place",
                  "isolated"
                ],
                "default": "in_place"
              },
              "authPreference": {
                "type": "string",
                "enum": [
                  "subscription",
                  "api_key",
                  "auto"
                ],
                "default": "auto"
              },
              "primaryHarness": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "eligibleHarnesses": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "portfolio": {
                "type": "string",
                "enum": [
                  "daily-rich",
                  "balanced",
                  "cheapest",
                  "strongest",
                  "burn",
                  "subscription-first",
                  "api-overflow",
                  "conserve-claude",
                  "conserve-codex"
                ]
              },
              "state": {
                "type": "string",
                "enum": [
                  "active",
                  "closed"
                ],
                "default": "active"
              },
              "runIds": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/ControlThreadListResponse/properties/threads/items/properties/id"
                },
                "default": []
              },
              "headRunId": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/ControlThreadListResponse/properties/threads/items/properties/id"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "needsHuman": {
                "type": "boolean",
                "default": false
              },
              "createdAt": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "createdAt",
              "updatedAt"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
