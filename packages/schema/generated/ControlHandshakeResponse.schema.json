{
  "$ref": "#/definitions/ControlHandshakeResponse",
  "definitions": {
    "ControlHandshakeResponse": {
      "type": "object",
      "properties": {
        "protocolMajor": {
          "type": "number",
          "const": 3
        },
        "compatible": {
          "type": "boolean",
          "const": true
        },
        "operationsPath": {
          "type": "string",
          "const": "/v2/operations"
        },
        "engine": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string",
              "minLength": 1,
              "description": "Lockstep workspace version."
            },
            "sha": {
              "type": "string",
              "minLength": 1,
              "description": "Git commit SHA of the build; 'unknown' outside a stamped package or git checkout."
            },
            "entry": {
              "type": "string",
              "minLength": 1,
              "description": "Resolved entry path of the serving process."
            }
          },
          "required": [
            "version",
            "sha",
            "entry"
          ],
          "additionalProperties": false,
          "description": "Build identity of the serving engine."
        }
      },
      "required": [
        "protocolMajor",
        "compatible",
        "operationsPath",
        "engine"
      ],
      "additionalProperties": false,
      "description": "Successful control-plane negotiation."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
