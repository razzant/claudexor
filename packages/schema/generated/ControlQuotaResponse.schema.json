{
  "$ref": "#/definitions/ControlQuotaResponse",
  "definitions": {
    "ControlQuotaResponse": {
      "type": "object",
      "properties": {
        "snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subject": {
                "type": "object",
                "properties": {
                  "harness": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Non-empty identifier string."
                  },
                  "credential_route": {
                    "type": "string",
                    "enum": [
                      "vendor_native",
                      "managed_api_key",
                      "local"
                    ]
                  },
                  "plan_label": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null
                  },
                  "subject_id": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "default": null
                  }
                },
                "required": [
                  "harness",
                  "credential_route"
                ],
                "additionalProperties": false,
                "description": "Quota owner and credential route; subject ids are opaque and optional."
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "$ref": "#/definitions/ControlQuotaResponse/properties/snapshots/items/properties/subject/properties/harness"
                    },
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "used_ratio": {
                      "anyOf": [
                        {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "window_seconds": {
                      "anyOf": [
                        {
                          "type": "number",
                          "exclusiveMinimum": 0
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "resets_at": {
                      "anyOf": [
                        {
                          "type": "string",
                          "format": "date-time"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "cooldown_until": {
                      "anyOf": [
                        {
                          "type": "string",
                          "format": "date-time"
                        },
                        {
                          "type": "null"
                        }
                      ],
                      "default": null
                    }
                  },
                  "required": [
                    "id",
                    "label",
                    "used_ratio",
                    "window_seconds",
                    "resets_at"
                  ],
                  "additionalProperties": false,
                  "description": "One independent vendor quota window; null usage stays unknown."
                }
              },
              "source": {
                "type": "string",
                "enum": [
                  "codex_app_server",
                  "codex_rollout",
                  "claude_statusline",
                  "claude_api_retry",
                  "claude_oauth_usage"
                ],
                "description": "Vendor-owned machine-readable source of a quota snapshot."
              },
              "observed_at": {
                "type": "string",
                "format": "date-time"
              },
              "freshness": {
                "type": "string",
                "enum": [
                  "fresh",
                  "stale",
                  "unknown"
                ],
                "description": "Freshness of a quota snapshot at read time."
              }
            },
            "required": [
              "subject",
              "constraints",
              "source",
              "observed_at",
              "freshness"
            ],
            "additionalProperties": false,
            "description": "All independently reported quota windows for one vendor-owned subject."
          }
        },
        "refreshed_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "snapshots",
        "refreshed_at"
      ],
      "additionalProperties": false,
      "description": "Current quota snapshots without a fabricated aggregate."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
