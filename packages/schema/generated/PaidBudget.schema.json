{
  "$ref": "#/definitions/PaidBudget",
  "definitions": {
    "PaidBudget": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "unlimited"
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "finite"
            },
            "maxUsd": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "maxUsd"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Incremental-cash budget: explicitly unlimited or a finite non-negative USD cap."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
