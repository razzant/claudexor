{
  "$ref": "#/definitions/BudgetObservation",
  "definitions": {
    "BudgetObservation": {
      "type": "object",
      "properties": {
        "harness_id": {
          "type": "string",
          "minLength": 1,
          "description": "Harness the observation is about."
        },
        "credential_route": {
          "type": "string",
          "enum": [
            "vendor_native",
            "managed_api_key",
            "local"
          ],
          "description": "Credential route the signal was observed on, when known."
        },
        "subject_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Credential-profile subject of the signal; null = engine default."
        },
        "ts": {
          "type": "string",
          "description": "When the signal was observed."
        },
        "quality": {
          "type": "string",
          "enum": [
            "exact",
            "native",
            "observed",
            "manual",
            "unknown"
          ],
          "description": "Quality of a usage/quota signal a harness can emit, from exact vendor accounting through native CLI reporting, engine observation, manual entry, to unknown."
        },
        "kind": {
          "type": "string",
          "enum": [
            "spend",
            "rate_limited",
            "quota_constraint",
            "cooldown"
          ],
          "description": "What was observed: spend, a rate-limit hit, one independent quota constraint, or a cooldown."
        },
        "usd": {
          "type": "number",
          "description": "Observed spend in USD, for spend observations."
        },
        "constraint_id": {
          "type": "string"
        },
        "used_ratio": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "window_seconds": {
          "anyOf": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "resets_at": {
          "type": [
            "string",
            "null"
          ],
          "description": "When the rate window resets, when reported."
        },
        "cooldown_until": {
          "type": [
            "string",
            "null"
          ],
          "description": "Until when the harness is in cooldown, when set."
        },
        "detail": {
          "type": "string",
          "description": "Redacted human-readable detail."
        }
      },
      "required": [
        "harness_id",
        "ts",
        "quality",
        "kind"
      ],
      "additionalProperties": false,
      "description": "An observed quota/usage signal (rate-limit error, used-percent, reset hint) recorded in the budget ledger."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
