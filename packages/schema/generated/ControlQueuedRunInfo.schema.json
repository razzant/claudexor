{
  "$ref": "#/definitions/ControlQueuedRunInfo",
  "definitions": {
    "ControlQueuedRunInfo": {
      "type": "object",
      "properties": {
        "jobId": {
          "type": "string",
          "description": "Daemon job id."
        },
        "state": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "blocked",
            "succeeded",
            "no_op",
            "ungated",
            "review_not_run",
            "failed",
            "cancelled",
            "interrupted_unknown",
            "cost_unverifiable",
            "exhausted_overshoot",
            "exhausted",
            "not_converged",
            "stuck_no_progress"
          ],
          "description": "Control-plane run state: queued/running while live, then an honest success, block, failure, interruption, cost, exhaustion, non-convergence, or cancellation terminal."
        },
        "error": {
          "type": "string",
          "description": "Error message, when the job failed."
        }
      },
      "required": [
        "jobId",
        "state"
      ],
      "additionalProperties": false,
      "description": "Compact state of a queued/running daemon job."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
