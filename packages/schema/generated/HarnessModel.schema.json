{
  "$ref": "#/definitions/HarnessModel",
  "definitions": {
    "HarnessModel": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Model id as the vendor enumerates it."
        },
        "label": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Human-readable model label; null when the enumeration source has none."
        },
        "context_window": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Context window in tokens; null when the enumeration source does not report it."
        },
        "routes": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "local_session",
                  "api_key"
                ]
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Credential routes the model is scoped to; null = every route."
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false,
      "description": "One enumerable model offered by a harness, limited to fields a real enumeration source can honestly populate."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
