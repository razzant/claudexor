{
  "$ref": "#/definitions/WorkspaceEnvelope",
  "definitions": {
    "WorkspaceEnvelope": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "$ref": "#/definitions/WorkspaceEnvelope/properties/id"
        },
        "attempt_id": {
          "$ref": "#/definitions/WorkspaceEnvelope/properties/id"
        },
        "repo_root": {
          "type": "string"
        },
        "base_ref": {
          "type": "string"
        },
        "base_sha": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "worktree_path": {
          "type": "string"
        },
        "branch_name": {
          "type": "string"
        },
        "env_dir": {
          "type": "string"
        },
        "home_dir": {
          "type": "string"
        },
        "harness_config_dirs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "ports": {
          "type": "object",
          "properties": {
            "allocated": {
              "type": "array",
              "items": {
                "type": "integer"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "allocated": []
          }
        },
        "policy_profile": {
          "type": "string",
          "default": "workspace_write"
        },
        "dirty_policy": {
          "type": "string",
          "enum": [
            "refuse",
            "snapshot"
          ],
          "default": "refuse"
        },
        "logs_dir": {
          "type": "string"
        },
        "artifacts_dir": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "task_id",
        "attempt_id",
        "repo_root",
        "base_ref",
        "worktree_path",
        "branch_name",
        "env_dir",
        "home_dir",
        "logs_dir",
        "artifacts_dir",
        "created_at"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
