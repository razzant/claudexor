{
  "$ref": "#/definitions/ControlSetupJobCreateRequest",
  "definitions": {
    "ControlSetupJobCreateRequest": {
      "type": "object",
      "properties": {
        "harness": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "cursor"
          ],
          "description": "Harness ids with a managed native-login flow."
        },
        "action": {
          "type": "string",
          "const": "login",
          "description": "The daemon-managed native-login action."
        },
        "authRequest": {
          "type": "string",
          "const": "subscription"
        }
      },
      "required": [
        "harness",
        "action",
        "authRequest"
      ],
      "additionalProperties": false,
      "description": "Request body to create an exact-subscription native-login job."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
