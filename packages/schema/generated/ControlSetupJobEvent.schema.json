            "queued",
            "running",
            "waiting_for_input",
            "succeeded",
            "failed",
            "cancelled",
            "timed_out",
            "interrupted_unknown",
            "not_supported"
          ],
          "description": "Lifecycle state of a setup job, including waiting_for_input (needs user confirmation/input) and not_supported."
        },
        "message": {
          "type": "string",
          "description": "Human-readable status message."
