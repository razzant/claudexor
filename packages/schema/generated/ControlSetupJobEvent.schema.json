            "phase": {
              "type": "string",
              "enum": [
                "preparing",
                "launching",
                "awaiting_user",
                "verifying",
                "cancelling",
                "completed"
              ],
              "description": "Fine-grained setup phase; cancellation remains a phase until the underlying process has actually stopped."
            },
            "deadlineAt": {
