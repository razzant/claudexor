                    "command_failed",
                    "auth_not_ready",
                    "capability_verification_failed",
                    "credential_route_mismatch",
                    "timed_out",
                    "cancelled_by_user",
                    "cancelled_on_restart",
                    "interrupted",
                    "interrupted_unknown",
                    "termination_unconfirmed"
