{
  "$ref": "#/definitions/ThreadTurn",
  "definitions": {
    "ThreadTurn": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Turn id."
        },
        "thread_id": {
          "type": "string",
          "minLength": 1,
          "description": "Thread the turn belongs to."
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "description": "Non-empty identifier string."
            },
            {
              "type": "null"
            }
          ],
          "description": "Run backing this turn; null while unbound.",
          "default": null
        },
        "parent_run_id": {
          "anyOf": [
            {
              "$ref": "#/definitions/ThreadTurn/properties/run_id/anyOf/0"
            },
            {
              "type": "null"
            }
          ],
          "description": "Run this turn follows up on, when any.",
          "default": null
        },
        "plan_run_id": {
          "anyOf": [
            {
              "$ref": "#/definitions/ThreadTurn/properties/run_id/anyOf/0"
            },
            {
              "type": "null"
            }
          ],
          "description": "Set when this turn implements an approved plan from an earlier plan run.",
          "default": null
        },
        "plan_hash": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "sha256 of the implemented plan at freeze time; null for non-implement turns."
        },
        "plan_readiness_overridden": {
          "type": "boolean",
          "default": false,
          "description": "True when the user explicitly implemented a plan with open questions."
        },
        "kind": {
          "type": "string",
          "enum": [
            "initial",
            "followup",
            "decision"
          ],
          "description": "Kind of thread turn: the initial message, a followup, or an operator decision turn.",
          "default": "followup"
        },
        "prompt": {
          "type": "string",
          "default": "",
          "description": "The user's message for this turn."
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resource_id": {
                "type": "string",
                "minLength": 1,
                "description": "Immutable daemon resource id."
              },
              "kind": {
                "type": "string",
                "enum": [
                  "image",
                  "file"
                ],
                "description": "Kind of attached resource: image input or generic file bytes."
              },
              "mime": {
                "type": "string",
                "minLength": 1,
                "description": "Declared MIME type validated against adapter limits."
              },
              "name": {
                "type": "string",
                "description": "Original display name."
              },
              "sha256": {
                "type": "string",
                "minLength": 1,
                "description": "Exact sha256 digest of the immutable bytes."
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0,
                "description": "Exact byte length."
              },
              "path": {
                "type": "string",
                "description": "Daemon-owned immutable blob path; internal adapter input only."
              }
            },
            "required": [
              "resource_id",
              "kind",
              "mime",
              "name",
              "sha256",
              "size_bytes",
              "path"
            ],
            "additionalProperties": false,
            "description": "Daemon-resolved immutable resource supplied to a harness adapter."
          },
          "default": [],
          "description": "Files/images the user attached to this turn (resolved scoped paths)."
        },
        "enqueue_error": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Human-readable refusal message."
                },
                "code": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "default": null,
                  "description": "Machine-readable refusal code carried from the throwing gate; null when the failure had no typed code."
                },
                "retryable": {
                  "type": "boolean",
                  "default": true,
                  "description": "True when retry can replay this turn (a job was recorded before the failure); false when no job exists to replay."
                },
                "failed_at": {
                  "type": "string",
                  "minLength": 1,
                  "description": "When the enqueue failed."
                }
              },
              "required": [
                "message",
                "failed_at"
              ],
              "additionalProperties": false,
              "description": "Typed record of a turn whose run could not be enqueued/started, persisted on the turn so every surface renders the refusal inline; cleared when a retry binds a run."
            },
            {
              "type": "null"
            }
          ],
          "description": "Why this turn has no run (enqueue/preflight refusal); null once a run binds.",
          "default": null
        },
        "continuity": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "native_resume",
                    "packet",
                    "fresh"
                  ],
                  "description": "How a turn's lane was continued: native_resume (the lane's own vendor session already held the delta), packet (a continuation packet hydrated a lane switch/gap), or fresh (nothing to carry — the thread's first turn on any lane)."
                },
                "packet_turns": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 0,
                  "description": "Number of delta turns carried in the continuation packet (0 for native_resume/fresh)."
                },
                "summarized": {
                  "type": "boolean",
                  "default": false,
                  "description": "True when the packet collapsed an older prefix to one-line entries (mechanical fallback)."
                },
                "lane_switched_from": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "harness_id": {
                          "type": "string",
                          "minLength": 1,
                          "description": "Harness of the prior lane."
                        },
                        "profile_id": {
                          "anyOf": [
                            {
                              "$ref": "#/definitions/ThreadTurn/properties/run_id/anyOf/0"
                            },
                            {
                              "type": "null"
                            }
                          ],
                          "description": "Credential profile of the prior lane (null = engine default).",
                          "default": null
                        }
                      },
                      "required": [
                        "harness_id"
                      ],
                      "additionalProperties": false,
                      "description": "A (harness, profile) lane reference; the null profile is the engine default."
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "description": "The lane this turn switched away from, when the continuation crossed lanes; null otherwise.",
                  "default": null
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false,
              "description": "How a turn's lane was continued from the conversation (native resume / continuation packet / fresh), disclosed visibly per INV-137."
            },
            {
              "type": "null"
            }
          ],
          "description": "How this turn's lane was continued (native resume / packet / fresh); null until stamped.",
          "default": null
        },
        "created_at": {
          "type": "string",
          "minLength": 1,
          "description": "When the turn was created."
        }
      },
      "required": [
        "id",
        "thread_id",
        "created_at"
      ],
      "additionalProperties": false,
      "description": "One follow-up unit within a thread; a run is its backing execution."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
