{
  "$ref": "#/definitions/ControlJournalInspection",
  "definitions": {
    "ControlJournalInspection": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "partition": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "generation": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "recovery_required"
          ]
        },
        "recovery": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "const": "ready"
                },
                "discardedTailBytes": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "status",
                "discardedTailBytes"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "const": "recovery_required"
                },
                "location": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "byte"
                        },
                        "byteOffset": {
                          "type": "integer",
                          "minimum": 0
                        }
                      },
                      "required": [
                        "kind",
                        "byteOffset"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "cursor"
                        },
                        "epoch": {
                          "type": "string",
                          "minLength": 1
                        },
                        "seq": {
                          "type": "integer",
                          "minimum": 0
                        }
                      },
                      "required": [
                        "kind",
                        "epoch",
                        "seq"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "discardedTailBytes": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "status",
                "location",
                "reason",
                "discardedTailBytes"
              ],
              "additionalProperties": false
            }
          ]
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      },
      "required": [
        "schemaVersion",
        "partition",
        "generation",
        "status",
        "recovery",
        "fingerprint",
        "observedAt",
        "evidenceRefs"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
