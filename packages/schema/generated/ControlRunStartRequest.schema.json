{
  "$ref": "#/definitions/ControlRunStartRequest",
  "definitions": {
    "ControlRunStartRequest": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "default": ""
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "image",
                  "file"
                ],
                "default": "file"
              },
              "mime": {
                "type": "string",
                "default": "application/octet-stream"
              },
              "name": {
                "type": "string",
                "default": ""
              },
              "data": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "path": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              }
            },
            "additionalProperties": false
          }
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "plan",
            "audit",
            "agent",
            "orchestrate"
          ],
          "default": "agent"
        },
        "scope": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string"
                },
                "context": {
                  "type": "string",
                  "enum": [
                    "auto",
                    "deep"
                  ],
                  "default": "auto"
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "none"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            }
          ],
          "default": {
            "kind": "none"
          }
        },
        "execution": {
          "type": "object",
          "properties": {
            "isolation": {
              "type": "string",
              "enum": [
                "envelope",
                "live"
              ],
              "default": "envelope"
            }
          },
          "additionalProperties": false,
          "default": {
            "isolation": "envelope"
          }
        },
        "harnesses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "primaryHarness": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
        },
        "portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "model": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
        },
        "effort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ]
        },
        "reviewerModels": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
          },
          "propertyNames": {
            "enum": [
              "openai",
              "anthropic",
              "google",
              "cursor",
              "opencode",
              "xai",
              "local",
              "unknown"
            ]
          }
        },
        "reviewerEfforts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ControlRunStartRequest/properties/effort"
          },
          "propertyNames": {
            "enum": [
              "openai",
              "anthropic",
              "google",
              "cursor",
              "opencode",
              "xai",
              "local",
              "unknown"
            ]
          }
        },
        "n": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "attempts": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "untilClean": {
          "type": "boolean"
        },
        "swarm": {
          "type": "boolean"
        },
        "create": {
          "type": "boolean"
        },
        "synthesis": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ]
        },
        "maxUsd": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ]
        },
        "web": {
          "type": "string",
          "enum": [
            "off",
            "auto",
            "cached",
            "live"
          ]
        },
        "externalContextPolicy": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/web"
        },
        "browser": {
          "type": "boolean"
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
          }
        },
        "protectedPathApprovals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
              },
              "reason": {
                "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
              }
            },
            "required": [
              "path"
            ],
            "additionalProperties": false
          }
        },
        "envProfile": {
          "type": "string"
        },
        "specPath": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
        },
        "specId": {
          "type": "string"
        },
        "specHash": {
          "type": "string",
          "minLength": 1
        },
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "turnId": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/threadId"
        },
        "parentRunId": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/threadId"
        },
        "planRunId": {
          "$ref": "#/definitions/ControlRunStartRequest/properties/threadId"
        },
        "reviewerPanel": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "harness": {
                "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
              },
              "model": {
                "$ref": "#/definitions/ControlRunStartRequest/properties/harnesses/items"
              },
              "effort": {
                "$ref": "#/definitions/ControlRunStartRequest/properties/effort"
              }
            },
            "required": [
              "harness"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "authPreference": {
          "type": "string",
          "enum": [
            "subscription",
            "api_key",
            "auto"
          ]
        },
        "autonomy": {
          "type": "string",
          "enum": [
            "suggest",
            "auto_safe",
            "auto_full"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
