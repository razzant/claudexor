{
  "$ref": "#/definitions/ControlRunStartRequest",
  "definitions": {
    "ControlRunStartRequest": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "default": ""
        },
        "mode": {
          "type": "string",
          "enum": [
            "ask",
            "explore",
            "agent",
            "best_of_n",
            "max_attempts",
            "until_clean",
            "plan",
            "create",
            "readonly_audit"
          ],
          "default": "agent"
        },
        "scope": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "project"
                },
                "root": {
                  "type": "string"
                },
                "context": {
                  "type": "string",
                  "enum": [
                    "auto",
                    "deep"
                  ],
                  "default": "auto"
                }
              },
              "required": [
                "kind",
                "root"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "none"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            }
          ],
          "default": {
            "kind": "none"
          }
        },
        "execution": {
          "type": "object",
          "properties": {
            "isolation": {
              "type": "string",
              "enum": [
                "envelope",
                "live"
              ],
              "default": "envelope"
            }
          },
          "additionalProperties": false,
          "default": {
            "isolation": "envelope"
          }
        },
        "harnesses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryHarness": {
          "type": "string"
        },
        "portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ]
        },
        "model": {
          "type": "string"
        },
        "effort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ]
        },
        "reviewerModels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "reviewerEfforts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ControlRunStartRequest/properties/effort"
          },
          "propertyNames": {
            "enum": [
              "openai",
              "anthropic",
              "google",
              "cursor",
              "opencode",
              "xai",
              "local",
              "unknown"
            ]
          }
        },
        "n": {
          "type": "integer",
          "exclusiveMinimum": true,
          "minimum": 0
        },
        "attempts": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": true,
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "maxUsd": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "access": {
          "type": "string",
          "enum": [
            "readonly",
            "workspace_write",
            "full",
            "external_sandbox_full",
            "inherit_native"
          ]
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "envProfile": {
          "type": "string"
        },
        "specPath": {
          "type": "string"
        },
        "specId": {
          "type": "string"
        },
        "specHash": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
