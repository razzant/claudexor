{
  "$ref": "#/definitions/ProjectConfig",
  "definitions": {
    "ProjectConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1
        },
        "context": {
          "type": "object",
          "properties": {
            "mandatory_files": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "tests": {
          "type": "object",
          "properties": {
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "commands": []
          }
        },
        "budget": {
          "type": "object",
          "properties": {
            "portfolio": {
              "type": "string",
              "enum": [
                "daily-rich",
                "balanced",
                "cheapest",
                "strongest",
                "burn",
                "subscription-first",
                "api-overflow",
                "conserve-claude",
                "conserve-codex"
              ],
              "default": "subscription-first"
            }
          },
          "additionalProperties": false,
          "default": {
            "portfolio": "subscription-first"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
