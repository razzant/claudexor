{
  "$ref": "#/definitions/ProjectConfig",
  "definitions": {
    "ProjectConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1,
          "description": "Config format version."
        },
        "context": {
          "type": "object",
          "properties": {
            "mandatory_files": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Files every context pack must include."
            },
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Globs to include in context building."
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Globs to exclude from context building."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Context-building preferences for the project."
        },
        "tests": {
          "type": "object",
          "properties": {
            "commands": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "program": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S",
                    "description": "Executable invoked directly without an implicit shell."
                  },
                  "args": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": [],
                    "description": "Exact argv passed to the executable."
                  },
                  "cwd": {
                    "type": "string",
                    "description": "Optional project-relative working directory for the command."
                  },
                  "envAllowlist": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "\\S",
                      "description": "User-supplied string that must contain visible content, not just whitespace."
                    },
                    "default": [],
                    "description": "Non-secret parent environment names explicitly forwarded to the command."
                  }
                },
                "required": [
                  "program"
                ],
                "additionalProperties": false,
                "description": "Canonical deterministic command invocation; no implicit shell parsing."
              },
              "default": [],
              "description": "Typed-argv test commands run as deterministic gates."
            }
          },
          "additionalProperties": false,
          "default": {
            "commands": []
          },
          "description": "Project-configured deterministic test gates."
        },
        "budget": {
          "type": "object",
          "properties": {
            "routing_goal": {
              "type": "string",
              "enum": [
                "auto",
                "quality",
                "economy"
              ],
              "description": "Routing objective: pace expiring quota, choose the highest declared quality tier, or minimize incremental paid spend."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Safe project routing preference; paid fallback remains user-global."
        }
      },
      "additionalProperties": false,
      "description": "Project config (.claudexor/config.yaml) — safe, versioned settings only; sensitive settings live in global/user-local/trust configs."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
