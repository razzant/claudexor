{
  "$ref": "#/definitions/GateResult",
  "definitions": {
    "GateResult": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "timed_out"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "stdout_tail": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "stderr_tail": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "output_truncated": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "id",
        "command",
        "exit_code",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
