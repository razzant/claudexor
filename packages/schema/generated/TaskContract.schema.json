{
  "$ref": "#/definitions/TaskContract",
  "definitions": {
    "TaskContract": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "number",
          "const": 2
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "object",
          "properties": {
            "root": {
              "type": "string"
            },
            "base_ref": {
              "type": "string"
            },
            "base_sha": {
              "type": "string"
            },
            "dirty_policy": {
              "type": "string",
              "enum": [
                "refuse",
                "include",
                "stash",
                "copy",
                "snapshot"
              ],
              "default": "refuse"
            }
          },
          "required": [
            "root",
            "base_ref"
          ],
          "additionalProperties": false
        },
        "mode": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "ask",
                "plan",
                "audit",
                "agent",
                "orchestrate"
              ]
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false
        },
        "user_intent": {
          "type": "object",
          "properties": {
            "raw": {
              "type": "string"
            },
            "normalized": {
              "type": "string"
            }
          },
          "required": [
            "raw"
          ],
          "additionalProperties": false
        },
        "spec": {
          "type": "object",
          "properties": {
            "id": {
              "$ref": "#/definitions/TaskContract/properties/task_id"
            },
            "hash": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "env_profile": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/definitions/TaskContract/properties/task_id"
              },
              "text": {
                "type": "string"
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            },
            "required": [
              "id",
              "text"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "forbidden_approaches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "decided_tradeoffs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "task_graph": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "nodes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "$ref": "#/definitions/TaskContract/properties/task_id"
                      },
                      "title": {
                        "type": "string",
                        "default": ""
                      },
                      "depends_on": {
                        "type": "array",
                        "items": {
                          "$ref": "#/definitions/TaskContract/properties/task_id"
                        },
                        "default": []
                      }
                    },
                    "required": [
                      "id"
                    ],
                    "additionalProperties": false
                  },
                  "default": []
                },
                "order": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/TaskContract/properties/task_id"
                  },
                  "default": []
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "constraints": {
          "type": "object",
          "properties": {
            "protected_paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "auto_protected_paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "protected_path_approvals": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "reason": {
                    "$ref": "#/definitions/TaskContract/properties/constraints/properties/protected_path_approvals/items/properties/path"
                  }
                },
                "required": [
                  "path"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "tests": {
          "type": "object",
          "properties": {
            "commands": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "$ref": "#/definitions/TaskContract/properties/task_id"
                  },
                  "command": {
                    "type": "string"
                  },
                  "required": {
                    "type": "boolean",
                    "default": true
                  }
                },
                "required": [
                  "id",
                  "command"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "commands": []
          }
        },
        "access": {
          "type": "object",
          "properties": {
            "requested_profile": {
              "type": "string",
              "enum": [
                "readonly",
                "workspace_write",
                "full",
                "external_sandbox_full",
                "inherit_native"
              ],
              "default": "workspace_write"
            },
            "effective_profile": {
              "$ref": "#/definitions/TaskContract/properties/access/properties/requested_profile",
              "default": "workspace_write"
            }
          },
          "additionalProperties": false,
          "default": {
            "requested_profile": "workspace_write",
            "effective_profile": "workspace_write"
          }
        },
        "external_context": {
          "type": "object",
          "properties": {
            "policy": {
              "type": "string",
              "enum": [
                "off",
                "auto",
                "cached",
                "live"
              ],
              "default": "auto"
            },
            "web_required": {
              "type": "boolean",
              "default": false
            },
            "effective_mode": {
              "$ref": "#/definitions/TaskContract/properties/external_context/properties/policy",
              "default": "auto"
            }
          },
          "additionalProperties": false,
          "default": {
            "policy": "auto",
            "web_required": false,
            "effective_mode": "auto"
          }
        },
        "tool_permission_policy": {
          "type": "object",
          "properties": {
            "web": {
              "$ref": "#/definitions/TaskContract/properties/external_context/properties/policy",
              "default": "auto"
            },
            "allow": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "deny": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "web": "auto",
            "allow": [],
            "deny": []
          }
        },
        "budget": {
          "type": "object",
          "properties": {
            "portfolio": {
              "type": "string",
              "enum": [
                "daily-rich",
                "balanced",
                "cheapest",
                "strongest",
                "burn",
                "subscription-first",
                "api-overflow",
                "conserve-claude",
                "conserve-codex"
              ],
              "default": "subscription-first"
            },
            "max_usd": {
              "type": [
                "number",
                "null"
              ],
              "default": null
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "routing_models": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "convergence": {
          "type": "object",
          "properties": {
            "require_tests_pass": {
              "type": "boolean",
              "default": true
            },
            "require_no_accepted_block_open": {
              "type": "boolean",
              "default": true
            },
            "require_no_accepted_fix_first_open": {
              "type": "boolean",
              "default": true
            },
            "require_final_cross_family_clean_review": {
              "type": "boolean",
              "default": true
            },
            "require_final_diff_stable_after_review": {
              "type": "boolean",
              "default": true
            },
            "require_no_accepted_needs_human_open": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "context_policy": {
          "type": "object",
          "properties": {
            "no_silent_truncation": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false,
          "default": {
            "no_silent_truncation": true
          }
        }
      },
      "required": [
        "schema_version",
        "task_id",
        "created_at",
        "repo",
        "mode",
        "user_intent"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
