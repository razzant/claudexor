{
  "$ref": "#/definitions/GlobalConfig",
  "definitions": {
    "GlobalConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1
        },
        "default_portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "benchmark",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ],
          "default": "subscription-first"
        },
        "routing": {
          "type": "object",
          "properties": {
            "default_policy": {
              "type": "string",
              "enum": [
                "auto",
                "primary",
                "portfolio"
              ],
              "default": "auto"
            },
            "primary_harness": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "eligible_harnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "default_model": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "env_inheritance": {
              "type": "string",
              "enum": [
                "mirror_native",
                "clean",
                "profile_only"
              ],
              "default": "mirror_native"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "budget": {
          "type": "object",
          "properties": {
            "max_usd_per_run": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "max_usd_per_day": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "default_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "auth_ref": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "ref": {
                        "type": "string",
                        "minLength": 1
                      },
                      "env": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "ref"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              }
            },
            "additionalProperties": false
          },
          "default": {}
        },
        "secrets": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "harnesses": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "env": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  }
}
