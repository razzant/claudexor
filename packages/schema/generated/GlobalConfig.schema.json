{
  "$ref": "#/definitions/GlobalConfig",
  "definitions": {
    "GlobalConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1,
          "description": "Config format version."
        },
        "interaction_timeout_ms": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 900000,
          "description": "How long an interactive run waits for the user's answer to a harness question before delivering a benign decline and letting the model continue."
        },
        "routing": {
          "type": "object",
          "properties": {
            "default_policy": {
              "type": "string",
              "enum": [
                "auto",
                "primary"
              ],
              "description": "Default routing policy: auto (engine picks) or primary (prefer the configured primary harness).",
              "default": "auto"
            },
            "primary_harness": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Global default primary harness; null = engine decides."
            },
            "eligible_harnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [],
              "description": "Harness pool eligible for routing/races; empty = all available."
            },
            "env_inheritance": {
              "type": "string",
              "enum": [
                "mirror_native",
                "clean"
              ],
              "default": "mirror_native",
              "description": "How the child harness env is built: mirror_native inherits the user's shell env; clean spawns from a minimal allowlist."
            },
            "auth_preference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret.",
              "default": "auto"
            },
            "goal": {
              "type": "string",
              "enum": [
                "auto",
                "quality",
                "economy"
              ],
              "description": "Routing objective: pace expiring quota, choose the highest declared quality tier, or minimize incremental paid spend.",
              "default": "auto"
            },
            "paid_fallback": {
              "type": "string",
              "enum": [
                "never",
                "when_unavailable",
                "allowed_within_cap"
              ],
              "description": "When a route with incremental paid spend may be used.",
              "default": "when_unavailable"
            },
            "quality_tiers": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "harness": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Non-empty identifier string."
                      },
                      "model": {
                        "type": "string",
                        "minLength": 1
                      },
                      "effort": {
                        "type": "string",
                        "enum": [
                          "low",
                          "medium",
                          "high",
                          "xhigh",
                          "max"
                        ],
                        "description": "Cross-harness reasoning-effort level, weakest to strongest; adapters declare the subset they support and a shared normalizer clamps requests onto the nearest supported level."
                      }
                    },
                    "required": [
                      "harness",
                      "model",
                      "effort"
                    ],
                    "additionalProperties": false,
                    "description": "An exact harness, model, and effort route declared by the user."
                  },
                  "minItems": 1,
                  "description": "A group of comparable exact routes at one user-declared quality level."
                }
              },
              "propertyNames": {
                "enum": [
                  "plan",
                  "spec",
                  "implement",
                  "create_from_scratch",
                  "repair",
                  "review",
                  "verify",
                  "synthesize",
                  "explain",
                  "audit",
                  "orchestrate"
                ]
              },
              "default": {},
              "description": "Per-intent quality tiers ordered highest to lowest; no provider or benchmark priors are inferred."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global routing defaults."
        },
        "budget": {
          "type": "object",
          "properties": {
            "paid_budget_per_run": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "unlimited"
                    }
                  },
                  "required": [
                    "kind"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "finite"
                    },
                    "maxUsd": {
                      "type": "number",
                      "minimum": 0
                    }
                  },
                  "required": [
                    "kind",
                    "maxUsd"
                  ],
                  "additionalProperties": false
                }
              ],
              "description": "Incremental-cash budget: explicitly unlimited or a finite non-negative USD cap.",
              "default": {
                "kind": "unlimited"
              }
            },
            "estimate_usd_floor": {
              "type": "number",
              "minimum": 0,
              "default": 0.05,
              "description": "Per-candidate USD reservation floor held against the run cap for every race-wave slot after the first, so a parallel wave cannot blow past the cap between settlements."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global budget limits."
        },
        "runtime": {
          "type": "object",
          "properties": {
            "transient_retry": {
              "type": "object",
              "properties": {
                "max_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 5,
                  "default": 2,
                  "description": "Maximum retries for a transient failure."
                },
                "initial_delay_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 1000,
                  "description": "Initial retry delay in milliseconds."
                },
                "max_delay_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10000,
                  "description": "Maximum retry delay in milliseconds."
                }
              },
              "additionalProperties": false,
              "default": {},
              "description": "Bounded retry policy for adapter-declared transient failures; user-global only."
            },
            "reviewer_timeout_ms": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 600000,
              "description": "Wall-clock timeout for a reviewer run, in milliseconds."
            },
            "harness_inactivity_timeout_ms": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 1200000,
              "description": "Inactivity watchdog for harness streams: no events for this window aborts the stream and fails the attempt with a typed timeout."
            }
          },
          "additionalProperties": false,
          "default": {},
          "description": "Global runtime timeouts and retry policy."
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether the harness participates in routing."
              },
              "default_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Per-harness default model; null = the harness's own default."
              },
              "effort": {
                "anyOf": [
                  {
                    "$ref": "#/definitions/GlobalConfig/properties/routing/properties/quality_tiers/additionalProperties/items/items/properties/effort"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Default reasoning effort for the harness; null = harness default.",
                "default": null
              },
              "max_turns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Default max agent turns; null = no limit."
              },
              "max_rounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Default max convergence rounds; null = engine default."
              },
              "tools_allow": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Tool names allowed for this harness."
              },
              "tools_deny": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Tool names denied for this harness."
              },
              "fallback_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null,
                "description": "Model to fall back to on typed fallback signals; null = none."
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ],
                "description": "Default web policy for this harness.",
                "default": "auto"
              },
              "auth_preference": {
                "$ref": "#/definitions/GlobalConfig/properties/routing/properties/auth_preference",
                "default": "auto",
                "description": "Preferred auth route: subscription (native/OAuth session), api_key (a stored API key), or auto (engine picks subscription-first with policy fallback). A preference, not a secret."
              }
            },
            "additionalProperties": false,
            "description": "Per-harness settings."
          },
          "default": {},
          "description": "Per-harness settings keyed by harness id."
        }
      },
      "additionalProperties": false,
      "description": "Claudexor v2 global user config (~/.claudexor/v2/config.yaml): routing, budget, runtime, and per-harness settings."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
