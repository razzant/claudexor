{
  "$ref": "#/definitions/GlobalConfig",
  "definitions": {
    "GlobalConfig": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1,
          "default": 1
        },
        "default_portfolio": {
          "type": "string",
          "enum": [
            "daily-rich",
            "balanced",
            "cheapest",
            "strongest",
            "burn",
            "subscription-first",
            "api-overflow",
            "conserve-claude",
            "conserve-codex"
          ],
          "default": "subscription-first"
        },
        "interaction_timeout_ms": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 900000
        },
        "routing": {
          "type": "object",
          "properties": {
            "default_policy": {
              "type": "string",
              "enum": [
                "auto",
                "primary",
                "portfolio"
              ],
              "default": "auto"
            },
            "primary_harness": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "eligible_harnesses": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "env_inheritance": {
              "type": "string",
              "enum": [
                "mirror_native",
                "clean"
              ],
              "default": "mirror_native"
            },
            "auth_preference": {
              "type": "string",
              "enum": [
                "subscription",
                "api_key",
                "auto"
              ],
              "default": "auto"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "budget": {
          "type": "object",
          "properties": {
            "max_usd_per_run": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "estimate_usd_floor": {
              "type": "number",
              "minimum": 0,
              "default": 0.05
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "runtime": {
          "type": "object",
          "properties": {
            "transient_retry": {
              "type": "object",
              "properties": {
                "max_retries": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 5,
                  "default": 2
                },
                "initial_delay_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 1000
                },
                "max_delay_ms": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 10000
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "reviewer_timeout_ms": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 600000
            },
            "harness_inactivity_timeout_ms": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 1200000
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "default_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "effort": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "xhigh",
                      "max"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "max_turns": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "max_rounds": {
                "anyOf": [
                  {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "max_usd": {
                "anyOf": [
                  {
                    "type": "number",
                    "minimum": 0
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              },
              "tools_allow": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "tools_deny": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "fallback_model": {
                "type": [
                  "string",
                  "null"
                ],
                "default": null
              },
              "web": {
                "type": "string",
                "enum": [
                  "off",
                  "auto",
                  "cached",
                  "live"
                ],
                "default": "auto"
              },
              "auth_preference": {
                "$ref": "#/definitions/GlobalConfig/properties/routing/properties/auth_preference",
                "default": "auto"
              }
            },
            "additionalProperties": false
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
