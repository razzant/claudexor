{
  "name": "@claudex/schema",
  "version": "0.1.0",
  "description": "Single source of truth for all Claudex data shapes (Zod + generated JSON Schema).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "zod-to-json-schema": "^3.24.1"
  }
}
