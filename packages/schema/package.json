{
  "name": "@claudexor/schema",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Single source of truth for all Claudexor data shapes (Zod + generated JSON Schema).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generated/*.schema.json": "./generated/*.schema.json"
  },
  "files": [
    "dist",
    "generated"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joi-lab/claudexor.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/joi-lab/claudexor#readme",
  "bugs": {
    "url": "https://github.com/joi-lab/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
