{
  "name": "@claudexor/control-api",
  "version": "3.1.0",
  "license": "MIT",
  "description": "Loopback HTTP+SSE control surface for GUI/service clients: token-auth, Host/Origin guard, live run event stream with Last-Event-ID replay. Runner injected (no second scheduler).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/delivery": "workspace:*",
    "@claudexor/event-log": "workspace:*",
    "@claudexor/schema": "workspace:*",
    "@claudexor/secrets": "workspace:*",
    "@claudexor/util": "workspace:*",
    "yaml": "^2.6.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razzant/claudexor.git",
    "directory": "packages/control-api"
  },
  "homepage": "https://github.com/razzant/claudexor#readme",
  "bugs": {
    "url": "https://github.com/razzant/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
