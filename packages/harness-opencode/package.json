{
  "name": "@claudex/harness-opencode",
  "version": "0.4.0",
  "description": "OpenCode adapter (opencode run --format json).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudex/core": "workspace:*",
    "@claudex/schema": "workspace:*",
    "@claudex/secrets": "workspace:*",
    "@claudex/util": "workspace:*"
  }
}
