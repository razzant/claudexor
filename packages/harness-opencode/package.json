{
  "name": "@claudexor/harness-opencode",
  "version": "0.10.2",
  "description": "OpenCode adapter (opencode run --format json).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/core": "workspace:*",
    "@claudexor/schema": "workspace:*",
    "@claudexor/secrets": "workspace:*",
    "@claudexor/util": "workspace:*"
  }
}
