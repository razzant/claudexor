{
  "name": "@claudexor/adapter-protocol",
  "version": "0.7.0",
  "description": "JSON-RPC-over-stdio protocol so external adapters (any language) can implement HarnessAdapter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/core": "workspace:*",
    "@claudexor/schema": "workspace:*"
  }
}
