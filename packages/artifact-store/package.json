{
  "name": "@claudexor/artifact-store",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Files-first canonical artifact store (repo-local .claudexor/runs layout).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/util": "workspace:*",
    "yaml": "^2.6.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joi-lab/claudexor.git",
    "directory": "packages/artifact-store"
  },
  "homepage": "https://github.com/joi-lab/claudexor#readme",
  "bugs": {
    "url": "https://github.com/joi-lab/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  }
}
