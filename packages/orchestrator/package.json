{
  "name": "@claudexor/orchestrator",
  "version": "2.1.3",
  "license": "MIT",
  "description": "Hub that composes all subsystems and implements the five canonical modes (ask, plan, audit, agent, orchestrate) with their strategy flags (best-of-N race, attempt caps, until-clean, swarm, create).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/arbitration": "workspace:*",
    "@claudexor/artifact-store": "workspace:*",
    "@claudexor/budget": "workspace:*",
    "@claudexor/config": "workspace:*",
    "@claudexor/context": "workspace:*",
    "@claudexor/core": "workspace:*",
    "@claudexor/delivery": "workspace:*",
    "@claudexor/event-log": "workspace:*",
    "@claudexor/gateway": "workspace:*",
    "@claudexor/policy": "workspace:*",
    "@claudexor/review": "workspace:*",
    "@claudexor/schema": "workspace:*",
    "@claudexor/synthesis": "workspace:*",
    "@claudexor/util": "workspace:*",
    "@claudexor/workspace": "workspace:*",
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@claudexor/harness-fake": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razzant/claudexor.git",
    "directory": "packages/orchestrator"
  },
  "homepage": "https://github.com/razzant/claudexor#readme",
  "bugs": {
    "url": "https://github.com/razzant/claudexor/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
