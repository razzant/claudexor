{
  "name": "claudexor-benchmark-runner",
  "version": "0.6.0",
  "description": "BenchmarkRunner + SWE-bench Verified (predictions/report) with ablations; scaffolds for Terminal-Bench/OSWorld/ProgramBench.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@claudexor/schema": "workspace:*",
    "@claudexor/util": "workspace:*"
  }
}
