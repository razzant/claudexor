{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/cli": {
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/browser-mcp-launcher.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/schema": {
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/canary": {
      "entry": ["src/**/*.story.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/claudexor": {
      "entry": ["bin/*.js"],
      "project": ["bin/*.js"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "benchmarks/runner": {
      "project": ["src/**/*.ts"]
    },
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**/*.mjs"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "includeEntryExports": true,
  "rules": {
    "exports": "error",
    "types": "error",
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "optionalPeerDependencies": "off",
    "unlisted": "warn",
    "binaries": "off",
    "unresolved": "off",
    "duplicates": "warn",
    "enumMembers": "error",
    "nsExports": "off",
    "nsTypes": "off"
  }
}
